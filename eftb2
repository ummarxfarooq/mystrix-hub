function Hub.arGetBrainrotList()
    local entries = {}
    Hub.arDisplayToInfo = {}
    local displayCount = {}
    local nameIndex = {}

    local function addTool(tool, suffix)
        local name = tool:GetAttribute("BrainrotName")
        if not name or name == "" then return end
        local mut = Hub.arGetToolMutation(tool)
        local baseDisplay = name .. " [" .. mut .. "]" .. (suffix or "")
        local display = baseDisplay
        if displayCount[display] then
            displayCount[display] = displayCount[display] + 1
            display = baseDisplay .. " #" .. displayCount[display]
        else
            displayCount[display] = 1
        end
        nameIndex[name] = (nameIndex[name] or 0) + 1
        local idx = nameIndex[name]
        Hub.arDisplayToInfo[display] = { name = name, mutation = mut, index = idx }
        table.insert(entries, { display = display, mutRank = Hub.arGetMutationRank(mut) })
    end

    local bp = LocalPlayer:FindFirstChild("Backpack")
    if bp then
        for _, tool in pairs(bp:GetChildren()) do
            if tool:IsA("Tool") and tool:GetAttribute("BrainrotName") then
                addTool(tool, "")
            end
        end
    end
    local char = LocalPlayer.Character
    if char then
        for _, tool in pairs(char:GetChildren()) do
            if tool:IsA("Tool") and tool:GetAttribute("BrainrotName") then
                addTool(tool, " ★")
            end
        end
    end

    table.sort(entries, function(a, b)
        return a.mutRank < b.mutRank
    end)

    local list = {}
    for _, e in ipairs(entries) do
        table.insert(list, e.display)
    end

    if #list == 0 then table.insert(list, "No brainrots found") end
    return list
end

function Hub.startArLoop()
    if Hub.arMainLoop then task.cancel(Hub.arMainLoop) end
    Hub.arMainLoop = task.spawn(function()
        while Hub.arEnabled do
            if not Hub.arIsAcidRain() then
                if Hub.arLocked then Hub.arFullUnlock() end
                task.wait(0.5)
                continue
            end

            Hub.deleteVIPWalls()

            local doneSet = {}
            local queue = {}
            for _, display in ipairs(Hub.arSelectedBrainrots) do
                local info = Hub.arDisplayToInfo[display]
                if info and not doneSet[display] then
                    if not Hub.arToolInstanceHasDesiredMutation(info) then
                        table.insert(queue, { display = display, info = info })
                    else
                        doneSet[display] = true
                    end
                end
            end

            if #queue == 0 then
                if Hub.arLocked then Hub.arFullUnlock() end
                task.wait(0.5)
                continue
            end

            local cx = Hub.arGetCloudXZ()
            Hub.arApproachCloud(cx)

            for _, entry in ipairs(queue) do
                if not Hub.arEnabled then break end
                if not Hub.arIsAcidRain() then break end

                local display = entry.display
                local info    = entry.info

                if doneSet[display] then continue end
                if Hub.arToolInstanceHasDesiredMutation(info) then
                    doneSet[display] = true
                    continue
                end

                local tool = Hub.arFindToolForInfo(info)
                if not tool then continue end

                Hub.arCurrentBrainrot = display
                Hub.arEquipTool(tool)
                task.wait(0.3)

                cx = Hub.arGetCloudXZ()
                if cx then Hub.arTweenTo(cx, -20, Hub.AR_FARM_Y) end

                local inWaveDodge = false

                while Hub.arEnabled and Hub.arIsAcidRain() do
                    if not Hub.arIsAlive() then
                        Hub.arWaitForRespawn(info)
                        cx = Hub.arGetCloudXZ()
                        inWaveDodge = false
                        task.wait(0.05)
                        continue
                    end

                    cx = Hub.arGetCloudXZ()
                    local hrp = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
                    if not hrp then task.wait(0.05); continue end

                    if Hub.arWaveNearby() then
                        if not inWaveDodge then
                            inWaveDodge = true
                            local wx = cx or hrp.Position.X
                            Hub.arTweenTo(wx, -137, Hub.AR_FARM_Y)
                        else
                            Hub.arSnapY(Hub.AR_FARM_Y)
                        end
                    else
                        if inWaveDodge then
                            inWaveDodge = false
                            if cx then Hub.arTweenTo(cx, -20, Hub.AR_FARM_Y) end
                        else
                            if math.abs(hrp.Position.Y - Hub.AR_FARM_Y) > 1 then
                                Hub.arSnapY(Hub.AR_FARM_Y)
                            end
                            if cx and math.abs(hrp.Position.Z + 20) > 5 then
                                Hub.arTweenTo(cx, -20, Hub.AR_FARM_Y)
                            end
                        end
                    end

                    local currentTool = Hub.arGetEquippedBrainrot()
                    if currentTool then
                        local curMut = Hub.arGetToolMutation(currentTool)
                        local gotDesired = false
                        for _, d in ipairs(Hub.arDesiredMutations) do
                            if curMut == d then gotDesired = true; break end
                        end
                        if gotDesired then
                            Hub.arUnequip()
                            doneSet[display] = true
                            task.wait(0.2)
                            break
                        end
                    else
                        local reequip = Hub.arFindToolForInfo(info)
                        if reequip then Hub.arEquipTool(reequip) end
                        task.wait(0.3)
                    end

                    task.wait(0.05)
                end
            end

            Hub.arCurrentBrainrot = nil
            Hub.arFullUnlock()
            
            task.wait(0.5)
        end
        Hub.arFullUnlock()
    end)
end

function Hub.stopArLoop()
    Hub.arEnabled         = false
    Hub.arCurrentBrainrot = nil
    if Hub.arMainLoop then task.cancel(Hub.arMainLoop); Hub.arMainLoop = nil end
    if Hub.arCurrentTween then pcall(function() Hub.arCurrentTween:Cancel() end); Hub.arCurrentTween = nil end
    Hub.arFullUnlock()
end

