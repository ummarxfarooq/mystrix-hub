            refreshTowerPosition()
            goUnderground()
            if not tweenUnderground(towerPosition) then return end
            task.wait(3)
            fireCompletionRemote()
            task.wait(1)

            local hrp = getHRP()
            if not hrp then return end
            hrp.CFrame = CFrame.new(COLLECT_POSITION.X, 7, COLLECT_POSITION.Z)
            task.wait(3)

            local folder = Workspace:FindFirstChild("ActiveBrainrots")
            if folder then
                for _, rarityFolder in pairs(folder:GetChildren()) do
                    if rarityFolder:IsA("Folder") and shouldCollectRarity(rarityFolder.Name) then
                        for _, brainrot in pairs(rarityFolder:GetChildren()) do
                            if not brainrot.Parent then continue end
                            if not isPlayerAlive() then break end
                            local root = brainrot:FindFirstChild("Root")
                            if not root then continue end
                            local prompt = root:FindFirstChild("TakePrompt")
                            if not prompt or not prompt:IsA("ProximityPrompt") then continue end
                            fireproximityprompt(prompt)
                        end
                    end
                end
            end
            task.wait(0.5)

            -- Spawn logging so it doesn't block (only Infinity will be sent)
            task.spawn(logTowerReward)

            local MAX_RETRIES = 5
            local attempt = 0
            local retryCollect = shouldRetryCollectOnDeath()

            while attempt < MAX_RETRIES do
                attempt = attempt + 1

                hrp = getHRP()
                if not hrp then
                    local waited = 0
                    while not isPlayerAlive() and waited < 15 do
                        task.wait(0.5)
                        waited = waited + 0.5
                    end
                    hrp = getHRP()
                    if not hrp then return end
                end

                enableAntiRagdoll()
                hrp.CFrame = CFrame.new(hrp.Position.X, TWEEN_Y, hrp.Position.Y)
                task.wait(0.2)

                local reachedClaim = tweenUnderground(CLAIM_POSITION)

                if reachedClaim and isPlayerAlive() then
                    hrp = getHRP()
                    if not hrp then return end
                    hrp.CFrame = CFrame.new(CLAIM_POSITION.X, 3, CLAIM_POSITION.Z)
                    task.wait(0.5)

                    disableAntiRagdoll()
                    unequipAllTools()
                    justDeposited = false
                    towerBrought  = 0
                    updateTowerState()
                    return
                end

                local waited = 0
                while not isPlayerAlive() and waited < 15 do
                    task.wait(0.5)
                    waited = waited + 0.5
                end
                if not isPlayerAlive() then return end

                if not retryCollect then
                    continue
                end

                local target = findBrainrotOfSelectedRarity()
                if not target then
                    continue
                end

                pickupBrainrotUnderground(target)
                task.wait(0.3)
            end
        end)
    end

    local function startAutoFarm()
        if towerAutoFarmConnection then
            task.cancel(towerAutoFarmConnection)
        end
        towerAutoFarmConnection = task.spawn(function()
            while towerAutoFarmEnabled do
                local eventActive = isAnySkipEventActive()
                if eventActive then
                    if not pausedForEvents then
                        pausedForEvents = true
                        stopTween()
                        disableAntiRagdoll()
                    end
                    task.wait(1)
                    continue
                else
                    if pausedForEvents then
                        pausedForEvents = false
                    end
                end

                unequipAllTools()
                if not isPlayerAlive() then
                    task.wait(1)
                    continue
                end
                if not towerDepositsLabel then findTowerHUD() end
                if not towerMain then
                    findTower()
                    task.wait(0.5)
                    continue
                end
                updateTowerState()
                if towerCurrentPhase == "ready" then
                    startTrial()
                    task.wait(1)
                elseif towerCurrentPhase == "trial" then
                    updateDepositCountFromHUD()
                    if towerBrought < maxDepositsTarget then
                        if hasBrainrotForDeposit or hasBrainrotEquipped() then
                            depositAtTower()
                            task.wait(0.5)
                        else
                            if towerRequirement then
                                if justDeposited and os.time() - depositTime < 4 then
                                    task.wait(1)
                                else
                                    local brainrot = findBrainrotOnFloor()
                                    if brainrot then
                                        local collected = collectBrainrot(brainrot)
                                        if not collected then task.wait(0.5) end
                                    else
                                        task.wait(1)
                                    end
                                end
                            else
                                task.wait(0.5)
                            end
                        end
                    else
                        claimRewardAndCollectSpecial()
                        task.wait(1)
                    end
                elseif towerCurrentPhase == "cooldown" then
                    disableAntiRagdoll()
                    task.wait(5)
                elseif towerCurrentPhase == "complete" then
                    disableAntiRagdoll()
                    task.wait(3)
                elseif towerCurrentPhase == "unknown" then
                    task.wait(2)
                end
                task.wait(0.5)
            end
        end)
    end

