function Hub.lsLockAt(y)
    local char = LocalPlayer.Character
    if not char then return end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    local hum = char:FindFirstChildOfClass("Humanoid")
    if not hrp or not hum then return end
    pcall(function()
        hum.PlatformStand = true
        hum.AutoRotate    = false
        hum.WalkSpeed     = 0
        hum.JumpPower     = 0
        hum.UseJumpPower  = false
        for _, v in pairs(hrp:GetChildren()) do
            if v:IsA("BodyVelocity") or v:IsA("BodyPosition") or v:IsA("BodyGyro") then
                pcall(function() v:Destroy() end)
            end
        end
        if Hub.lsBodyVelocity then pcall(function() Hub.lsBodyVelocity:Destroy() end) end
        Hub.lsBodyVelocity = Instance.new("BodyVelocity")
        Hub.lsBodyVelocity.Velocity = Vector3.new(0, 0, 0)
        Hub.lsBodyVelocity.MaxForce = Vector3.new(9e9, 9e9, 9e9)
        Hub.lsBodyVelocity.P        = 1000000
        Hub.lsBodyVelocity.Parent   = hrp
        if not Hub.lsOrigGravity then Hub.lsOrigGravity = Workspace.Gravity end
        Workspace.Gravity = 0
        hrp.CFrame = CFrame.new(hrp.Position.X, y, hrp.Position.Z)
    end)
    Hub.lsLocked = true
end

function Hub.lsFullUnlock()
    if Hub.lsBodyVelocity then
        pcall(function() Hub.lsBodyVelocity:Destroy() end)
        Hub.lsBodyVelocity = nil
    end
    pcall(function()
        local char = LocalPlayer.Character
        if char then
            local hrp = char:FindFirstChild("HumanoidRootPart")
            if hrp then
                for _, v in pairs(hrp:GetChildren()) do
                    if v:IsA("BodyVelocity") or v:IsA("BodyPosition") or v:IsA("BodyGyro") then
                        pcall(function() v:Destroy() end)
                    end
                end
            end
            local hum = char:FindFirstChildOfClass("Humanoid")
            if hum then
                hum.PlatformStand = false
                hum.AutoRotate    = true
                hum.WalkSpeed     = 16
                hum.JumpPower     = 50
                hum.UseJumpPower  = true
                hum.MaxSlopeAngle = 89
            end
        end
    end)
    if Hub.lsOrigGravity then
        Workspace.Gravity = Hub.lsOrigGravity
        Hub.lsOrigGravity = nil
    else
        Workspace.Gravity = 196.2
    end
    Hub.lsLocked = false
end

