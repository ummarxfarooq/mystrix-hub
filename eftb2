    local function findBrainrotOnFloor()
        if not towerRequirement then return nil end
        if justDeposited and os.time() - depositTime < 4 then return nil end
        local folder = Workspace:FindFirstChild("ActiveBrainrots")
        if not folder then return nil end
        local rarityFolder = folder:FindFirstChild(towerRequirement)
        if not rarityFolder then return nil end
        local hrp = getHRP()
        if not hrp then return nil end
        local playerPos = hrp.Position
        local chosen = nil
        local closestDist = math.huge
        for _, brainrot in pairs(rarityFolder:GetChildren()) do
            if brainrot:IsA("Model") and brainrot.Parent then
                local root = brainrot:FindFirstChild("Root")
                if root then
                    local timeLeft = getBrainrotTimeLeft(brainrot)
                    if timeLeft < 4 then continue end
                    local dx = root.Position.X - playerPos.X
                    local dz = root.Position.Z - playerPos.Z
                    local d  = math.sqrt(dx*dx + dz*dz)
                    if chosen == nil then
                        chosen = brainrot
                        closestDist = d
                    else
                        local chosenTime = getBrainrotTimeLeft(chosen)
                        if timeLeft > chosenTime then
                            chosen = brainrot
                            closestDist = d
                        elseif timeLeft == chosenTime then
                            if pickBestEnabled then
                                if isBetterBrainrot(chosen, brainrot) then
                                    chosen = brainrot
                                    closestDist = d
                                end
                            else
                                if d < closestDist then
                                    chosen = brainrot
                                    closestDist = d
                                end
                            end
                        end
                    end
                end
            end
        end
        if chosen then
            currentTargetBrainrot = chosen
            local root = chosen:FindFirstChild("Root")
            if root then lastBrainrotPosition = root.Position end
            stuckCounter  = 0
            justDeposited = false
        end
        return chosen
    end

