function KeySystem:VerifyKey(inputKey, statusLabel)
    inputKey = cleanKey(inputKey)

    if not inputKey or inputKey == "" then
        showErrorMessage(self.mainFrame, "Please enter a key", 2)
        return
    end

    statusLabel.Text = "Verifying key..."
    statusLabel.TextColor3 = Color3.fromRGB(255, 255, 0)

    local expiryLabel = self.mainFrame:FindFirstChild("ExpiryLabel")
    if expiryLabel then expiryLabel.Visible = false end

    local success, result = verifyKey(inputKey)

    if success then
        statusLabel.Text = "ACCESS GRANTED!"
        statusLabel.TextColor3 = Color3.fromRGB(100, 255, 100)

        if result and result.validUntil then
            local ok, expiryTime = pcall(function()
                return DateTime.fromIsoDate(result.validUntil).UnixTimestamp
            end)
            saveKey(inputKey, ok and expiryTime or nil, result)
            updateExpiryDisplay(self.mainFrame, result.validUntil, result.expiresIn)
        else
            saveKey(inputKey, nil, result)
        end

        self.verified = true

        for i = 1, 2 do
            TweenService:Create(self.mainFrame, TweenInfo.new(0.1), {Size = self.mainFrame.Size + UDim2.new(0, 12, 0, 12)}):Play()
            task.wait(0.1)
            TweenService:Create(self.mainFrame, TweenInfo.new(0.1), {Size = self.mainFrame.Size - UDim2.new(0, 12, 0, 12)}):Play()
            task.wait(0.1)
        end

        self.mainGui:Destroy()
        local loadingGui = showLoadingGUI("LOADING SCRIPT")
        task.wait(0.5)
        self:LoadScript()
        task.wait(3)
        if loadingGui then loadingGui:Destroy() end

    else
        if result == "HWID_MISMATCH" and type(result) == "table" and result.hwidReset then
            statusLabel.Text = "HWID Reset Detected! Click Verify again."
            statusLabel.TextColor3 = Color3.fromRGB(255, 200, 0)

            if result.validUntil then
                updateExpiryDisplay(self.mainFrame, result.validUntil, result.expiresIn)
                local ok, expiryTime = pcall(function()
                    return DateTime.fromIsoDate(result.validUntil).UnixTimestamp
                end)
                saveKey(inputKey, ok and expiryTime or nil, result)
            end

            for i = 1, 2 do
                TweenService:Create(self.mainFrame, TweenInfo.new(0.1), {Size = self.mainFrame.Size + UDim2.new(0, 12, 0, 12)}):Play()
                task.wait(0.1)
                TweenService:Create(self.mainFrame, TweenInfo.new(0.1), {Size = self.mainFrame.Size - UDim2.new(0, 12, 0, 12)}):Play()
                task.wait(0.1)
            end

            self.mainGui:Destroy()
            local loadingGui = showLoadingGUI("LOADING SCRIPT")
            task.wait(0.5)
            self:LoadScript()
            task.wait(3)
            if loadingGui then loadingGui:Destroy() end
        else
            showErrorMessage(self.mainFrame, getFriendlyErrorMessage(result), 3)
            if expiryLabel then expiryLabel.Visible = false end
        end
    end
end

