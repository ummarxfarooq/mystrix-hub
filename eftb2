        end
    end)
end

local function loadSavedKey()
    local keyData = nil
    pcall(function()
        if isfile and readfile and isfile("MystrixHub.dat") then
            local ok, parsed = pcall(function() return HttpService:JSONDecode(readfile("MystrixHub.dat")) end)
            if ok and parsed and parsed.key then
                if parsed.expiry and os.time() >= parsed.expiry then
                    pcall(function() delfile("MystrixHub.dat") end)
                    return
                end
                keyData = {
                    key = cleanKey(parsed.key),
                    savedHwid = parsed.hwid,
                    expiry = parsed.expiry,
                    keyId = parsed.keyId,
                    validUntil = parsed.validUntil
                }
            else
                pcall(function() delfile("MystrixHub.dat") end)
            end
        end
    end)
    return keyData
end

