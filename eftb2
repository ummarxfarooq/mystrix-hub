function Hub.carnivalScaleCat(scale)
    local s = tonumber(scale)
    if not s then return "Default" end
    if s < 0.25 then return "Lil Baby"
    elseif s <= 0.39 then return "Baby"
    elseif s <= 0.74 then return "Mini"
    elseif s <= 1.24 then return "Default"
    elseif s <= 1.74 then return "Big"
    elseif s == 1.75 then return "Titan"
    else return "Colossal" end
end

function Hub.carnivalScaleOk(tool, filter)
    if not filter or #filter == 0 or table.find(filter, "Any") then return true end
    return table.find(filter, Hub.carnivalScaleCat(tool:GetAttribute("Scale"))) ~= nil
end

function Hub.carnivalMutOk(tool, filter)
    if not filter or #filter == 0 or table.find(filter, "Any") then return true end
    local mut = tool:GetAttribute("Mutation") or ""
    if table.find(filter, "None") and (mut == "" or mut == "None") then return true end
    return table.find(filter, mut) ~= nil
end

function Hub.carnivalFindByRarity(rarity, excluded, scaleF, mutF)
    excluded = excluded or {}
    local names = Hub.CarnivalBrainrotsByRarity[rarity]
    if not names then return nil end
    local pool = {}
    local bp = LocalPlayer:FindFirstChild("Backpack")
    if bp then
        for _, tool in pairs(bp:GetChildren()) do
            if tool:IsA("Tool") and table.find(names, tool:GetAttribute("BrainrotName") or "") then
                local ex = false
                for _, e in pairs(excluded) do if e == tool then ex = true; break end end
                if not ex and Hub.carnivalScaleOk(tool, scaleF) and Hub.carnivalMutOk(tool, mutF) then
                    table.insert(pool, tool)
                end
            end
        end
    end
    if #pool > 0 then return pool[math.random(1, #pool)] end
    return nil
end

