function Hub.attemptAutoLoad()
    local autoLoad = Hub.getAutoLoadSetting()
    if autoLoad then
        local lastConfig = Hub.loadLastConfigName()
        if lastConfig and lastConfig ~= "" then
            task.spawn(function()
                task.wait(0.5)
                local configToLoad = Hub.getConfig(lastConfig)
                local ok, err = pcall(function() configToLoad:Load() end)
                if ok then
                    Hub.selectedConfig = lastConfig
                    local newConfigs = Hub.getAllConfigNames()
                    if Hub.UI.ConfigDropdown1 then
                        Hub.UI.ConfigDropdown1:Refresh(newConfigs)
                    end
                    WindUI:Notify({
                        Title = "Auto Load",
                        Content = "Loaded last config: " .. lastConfig,
                        Duration = 3,
                        Icon = "check-circle",
                    })
                else
                    WindUI:Notify({
                        Title = "Auto Load Failed",
                        Content = tostring(err),
                        Duration = 3,
                        Icon = "alert-circle",
                    })
                end
            end)
        end
    end
end

