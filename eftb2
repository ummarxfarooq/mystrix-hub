function Hub.tnGetToolMutation(tool)
    if not tool then return "None" end
    local mut = tool:GetAttribute("Mutation")
    if mut and mut ~= "" then return tostring(mut) end
    local rendered = tool:FindFirstChild("RenderModel") or tool:FindFirstChild("RenderedBrainrot")
    if rendered then
        local rmut = rendered:GetAttribute("Mutation")
        if rmut then return tostring(rmut) end
    end
    return "None"
end

function Hub.tnFindTool(info)
    if not info then return nil end

    local function searchIn(container)
        local matches = {}
        for _, tool in pairs(container:GetChildren()) do
            if not tool:IsA("Tool") then continue end
            if info.isLucky then
                if tool:GetAttribute("LuckyBlockTool") == true then
                    local ltype = tostring(tool:GetAttribute("LuckyBlockType") or "")
                    if ltype == info.luckyType then
                        table.insert(matches, tool)
                    end
                end
            else
                if tool:GetAttribute("BrainrotName") == info.name then
                    table.insert(matches, tool)
                end
            end
        end
        return matches
    end

    local allMatches = {}
    local bp = LocalPlayer:FindFirstChild("Backpack")
    if bp then
        for _, t in pairs(searchIn(bp)) do table.insert(allMatches, t) end
    end
    local char = LocalPlayer.Character
    if char then
        for _, t in pairs(searchIn(char)) do table.insert(allMatches, t) end
    end

    return allMatches[info.index] or allMatches[1]
end

function Hub.tnIsItemEquipped(info)
