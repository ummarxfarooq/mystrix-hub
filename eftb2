function Hub.carnivalTweenTo()
    local char = LocalPlayer.Character
    if not char then return false end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if not hrp then return false end
    local pos = Hub.carnivalGetMachinePos()
    if not pos then return false end
    local dist = (hrp.Position - pos).Magnitude
    if dist < 5 then return true end
    local t = math.clamp(dist / math.max(Hub.carnivalTweenSpd, 1), 0.1, 15)
    local tween = TweenService:Create(hrp, TweenInfo.new(t, Enum.EasingStyle.Linear), { CFrame = CFrame.new(pos) })
    tween:Play()
    tween.Completed:Wait()
    return true
end

