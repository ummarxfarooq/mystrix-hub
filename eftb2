function Hub.onBrainrotAdded(brainrot, rarityName)
    if not Hub.webhookEnabled_Brainrot then return end
    if not Hub.shouldNotifyRarity(rarityName) then return end

    if Hub.webhookCooldowns[brainrot] then return end
    Hub.webhookCooldowns[brainrot] = true

    pcall(function()
        brainrot.AncestryChanged:Connect(function()
            if not brainrot.Parent then
                Hub.webhookCooldowns[brainrot] = nil
            end
        end)
    end)

    task.wait(0.3)
    if not brainrot or not brainrot.Parent then return end

    local rendered = Hub.getRendered(brainrot)
    local name     = tostring(Hub.getAttr(rendered, "BrainrotName") or brainrot.Name)
    local mutation = tostring(Hub.getAttr(rendered, "Mutation") or "None")
    local level    = tostring(Hub.getAttr(rendered, "Level") or 0)
    local timeLeft = tostring(Hub.getAttr(rendered, "TimeLeft") or 0)
    local traits   = tostring(Hub.getAttr(rendered, "Traits") or "None")

    if not Hub.shouldNotifyMutation(mutation) then return end
    if not Hub.shouldNotifyTrait(traits) then return end

    local color = Hub.RARITY_COLORS[rarityName] or 0x991B1B
    local desc  = "**Rarity:** " .. rarityName
        .. "\n**Name:** " .. name
        .. "\n**Mutation:** " .. mutation
        .. "\n**Traits:** " .. traits
        .. "\n**Level:** " .. level
        .. "\n**Time Left:** " .. timeLeft .. "s"

    Hub.send("Brainrot Spawned - " .. rarityName, desc, color, Hub.webhookEnabled_Brainrot)
end

function Hub.hookRarityFolder(rarityFolder)
    local rarityName = rarityFolder.Name
    if Hub.webhookBrainrotListeners[rarityName] then return end
    for _, b in pairs(rarityFolder:GetChildren()) do
        task.spawn(function() Hub.onBrainrotAdded(b, rarityName) end)
    end
    local conn = rarityFolder.ChildAdded:Connect(function(b)
        task.spawn(function() Hub.onBrainrotAdded(b, rarityName) end)
    end)
    Hub.webhookBrainrotListeners[rarityName] = conn
end

function Hub.startBrainrotListeners()
    for _, conn in pairs(Hub.webhookBrainrotListeners) do
        pcall(function() conn:Disconnect() end)
    end
    Hub.webhookBrainrotListeners = {}
    if Hub.webhookBrainrotFolderConn then
        pcall(function() Hub.webhookBrainrotFolderConn:Disconnect() end)
        Hub.webhookBrainrotFolderConn = nil
    end
    Hub.webhookCooldowns = {}

    local folder = Workspace:FindFirstChild("ActiveBrainrots")
        or Workspace:FindFirstChild("Brainrots")
        or RS:FindFirstChild("ActiveBrainrots")

    if not folder then
        warn("[Webhook] ActiveBrainrots folder not found")
        return
    end

    for _, f in pairs(folder:GetChildren()) do
        if f:IsA("Folder") or f:IsA("Model") then Hub.hookRarityFolder(f) end
    end

    Hub.webhookBrainrotFolderConn = folder.ChildAdded:Connect(function(f)
        if f:IsA("Folder") or f:IsA("Model") then Hub.hookRarityFolder(f) end
    end)
end

function Hub.stopBrainrotListeners()
    for _, conn in pairs(Hub.webhookBrainrotListeners) do
