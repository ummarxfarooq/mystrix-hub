                            .. "\n**Items:** " .. count .. "/100"
                            .. "\n**Backpack Full**, reached your selected limit!",
                            0xFF4444,
                            Hub.webhookEnabled_Inventory
                        )
                    end
                else
                    Hub.webhookInventoryNotified = false
                end
            end)
            task.wait(2)
        end
    end)
end

function Hub.stopInventoryPollLoop()
    if Hub.webhookInventoryPollThread then
        task.cancel(Hub.webhookInventoryPollThread)
        Hub.webhookInventoryPollThread = nil
