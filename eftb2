local autoCancelCandyEnabled = false
local candyCancelConnections = {}

local function killPlayer()
    local character = LocalPlayer.Character
    if character then
        local humanoid = character:FindFirstChildOfClass("Humanoid")
        if humanoid then
            humanoid.Health = 0
        end
    end
end

local function setupCandyCancel()
    for _, conn in pairs(candyCancelConnections) do
        pcall(function() conn:Disconnect() end)
    end
    candyCancelConnections = {}
    local ActiveMinigame
    pcall(function()
        ActiveMinigame = require(ReplicatedStorage.Client.Modules.ClientGlobals).ActiveMinigame
    end)
    if not ActiveMinigame then
        task.wait(2)
        setupCandyCancel()
        return
    end
    local BestOfGui = LocalPlayer.PlayerGui:WaitForChild("WagerGui"):WaitForChild("BestofGamemode", 5)
    if not BestOfGui then return end
    local phaseConn = ActiveMinigame:Observe({ "phase" }, function(phase)
        if autoCancelCandyEnabled and phase == "ChooseGameStyle" then
            local gameId = ActiveMinigame:TryIndex({ "gameId" })
            if gameId == "CandyBomb" then
                killPlayer()
            end
        end
    end)
    table.insert(candyCancelConnections, phaseConn)
    local visibleConn = BestOfGui:GetPropertyChangedSignal("Visible"):Connect(function()
        if autoCancelCandyEnabled and BestOfGui.Visible then
            local gameId = ActiveMinigame:TryIndex({ "gameId" })
            if gameId == "CandyBomb" then
                killPlayer()
            end
        end
    end)
    table.insert(candyCancelConnections, visibleConn)
    if autoCancelCandyEnabled then
        local phase = ActiveMinigame:TryIndex({ "phase" })
        local gameId = ActiveMinigame:TryIndex({ "gameId" })
        if phase == "ChooseGameStyle" and gameId == "CandyBomb" then
            killPlayer()
        end
        if BestOfGui.Visible and gameId == "CandyBomb" then
            killPlayer()
        end
    end
end

