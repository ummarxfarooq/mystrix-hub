    local dist = (Vector3.new(hrp.Position.X, 0, hrp.Position.Z) - Vector3.new(targetX, 0, targetZ)).Magnitude
    if dist < 2 then
        hrp.CFrame = CFrame.new(targetX, y, targetZ)
        return
    end
    local t = math.clamp(dist / Hub.tnTweenSpeed, 0.05, 8)
    Hub.tnCurrentTween = TweenService:Create(hrp, TweenInfo.new(t, Enum.EasingStyle.Linear), {
        CFrame = CFrame.new(targetX, y, targetZ)
    })
    Hub.tnCurrentTween:Play()
    local lockConn
    lockConn = RunService.Heartbeat:Connect(function()
        if not hrp or not hrp.Parent then lockConn:Disconnect(); return end
        hrp.CFrame = CFrame.new(hrp.Position.X, y, hrp.Position.Z)
    end)
    Hub.tnCurrentTween.Completed:Wait()
    lockConn:Disconnect()
end

