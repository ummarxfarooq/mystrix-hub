-- ========================================
-- KEY CLEANING
-- ========================================
local function cleanKey(key)
    if not key then return "" end
    key = tostring(key)
    key = key:match("^%s*(.-)%s*$")
    key = key:gsub("[%z\1-\8\11\12\14-\31\127]", "")
    key = key:gsub("\226\128\139", "")
    key = key:gsub("\226\128\138", "")
    key = key:gsub("\239\187\191", "")
    key = key:gsub("[^%w%-_]", "")
    return key
end

-- ========================================
-- RAW REQUEST FUNCTION
-- ========================================
local function makeRawRequest(url, method, headers, body)
    local args = { Url = url, Method = method or "GET" }
    if headers then args.Headers = headers end
    if body then args.Body = body end

    if request then
        local ok, resp = pcall(request, args)
        if ok and resp then return resp end
    end
    if syn and syn.request then
        local ok, resp = pcall(syn.request, args)
        if ok and resp then return resp end
    end
    if http and http.request then
        local ok, resp = pcall(http.request, args)
        if ok and resp then return resp end
    end
    if http_request then
        local ok, resp = pcall(http_request, args)
        if ok and resp then return resp end
    end
    return nil
end

-- ========================================
-- TIME SYNC (robust multi-source)
-- ========================================
local cachedServerTimeOffset = nil
local lastSyncTime = 0

local function tryParseUnixMs(resp)
    if not (resp and resp.Body) then return nil end
    local ok, data = pcall(function() return HttpService:JSONDecode(resp.Body) end)
    if not ok or not data then return nil end
    if data.unixtime then return math.floor(data.unixtime * 1000) end
    if data.now then return math.floor(data.now * 1000) end
    if data.dateTime then
        local ok2, dt = pcall(function() return DateTime.fromIsoDate(data.dateTime) end)
        if ok2 and dt then return dt.UnixTimestampMillis end
    end
    if data.utc_datetime then
        local ok2, dt = pcall(function() return DateTime.fromIsoDate(data.utc_datetime) end)
        if ok2 and dt then return dt.UnixTimestampMillis end
    end
    return nil
end

local function tryParseDateHeader(resp)
    if not (resp and resp.Headers) then return nil end
    local dateHeader = resp.Headers["date"] or resp.Headers["Date"]
    if not dateHeader then return nil end
    local day, mon, year, h, m, s = dateHeader:match("(%d+) (%a+) (%d+) (%d+):(%d+):(%d+)")
    local months = {Jan=1,Feb=2,Mar=3,Apr=4,May=5,Jun=6,Jul=7,Aug=8,Sep=9,Oct=10,Nov=11,Dec=12}
    if day and mon and year and months[mon] then
        local ok, serverTs = pcall(os.time, {
            year=tonumber(year), month=months[mon], day=tonumber(day),
            hour=tonumber(h), min=tonumber(m), sec=tonumber(s)
        })
        if ok then return serverTs * 1000 end
    end
    return nil
end

local function syncServerTime()
    if cachedServerTimeOffset ~= nil and (os.time() - lastSyncTime) < 60 then
        return true
    end

    -- JSON time APIs
    local jsonApis = {
        "https://worldtimeapi.org/api/timezone/Etc/UTC",
        "https://timeapi.io/api/Time/current/zone?timeZone=UTC",
        "https://www.timeapi.org/utc/now",
    }
    for _, url in ipairs(jsonApis) do
        local ok, resp = pcall(makeRawRequest, url, "GET", {["Accept"] = "application/json"}, nil)
        if ok and resp then
            local ms = tryParseUnixMs(resp)
            if ms then
                cachedServerTimeOffset = ms - DateTime.now().UnixTimestampMillis
                lastSyncTime = os.time()
                return true
            end
        end
    end

    -- Header-only fallbacks (Date header is always present)
    local headerApis = {
        "https://www.google.com/",
        "https://www.roblox.com/",
        "https://discord.com/",
        "https://github.com/",
    }
    for _, url in ipairs(headerApis) do
        local ok, resp = pcall(makeRawRequest, url, "GET", nil, nil)
        if ok and resp then
            local ms = tryParseDateHeader(resp)
            if ms then
                cachedServerTimeOffset = ms - DateTime.now().UnixTimestampMillis
                lastSyncTime = os.time()
                return true
            end
        end
    end

    cachedServerTimeOffset = 0
    lastSyncTime = os.time()
    return false
end

local function getAccurateTimestampMs(extraOffsetMs)
    if cachedServerTimeOffset == nil then syncServerTime() end
    return tostring(DateTime.now().UnixTimestampMillis + (cachedServerTimeOffset or 0) + (extraOffsetMs or 0))
end

-- ========================================
-- CRYPTO FUNCTIONS
-- ========================================
local function hex_to_bytes(hex)
    return (hex:gsub("..", function(cc)
        return string.char(tonumber(cc, 16))
    end))
end

local function bytes_to_hex(s)
    return (s:gsub(".", function(c)
        return string.format("%02x", string.byte(c))
    end))
end

local function isHex(s, expectedLen)
    if not s then return false end
    if expectedLen and #s ~= expectedLen then return false end
    return s:match("^[0-9a-fA-F]+$") ~= nil
end

local function normaliseSHA256(result)
    if not result or result == "" then return nil end
    local len = #result
    if len == 64 and isHex(result, 64) then
        return hex_to_bytes(result)
    elseif len == 32 then
        return result
    elseif isHex(result) then
        return hex_to_bytes(result)
    end
    return result
end

local function sha256_bytes(data)
    local ok, result

    ok, result = pcall(function()
        return crypt and crypt.hash and crypt.hash(data, "sha256")
    end)
    if ok and result and result ~= "" then
        local norm = normaliseSHA256(result)
        if norm then return norm end
    end

    ok, result = pcall(function()
        return game:GetService("HttpService"):SHA256(data)
    end)
    if ok and result and result ~= "" then
        local norm = normaliseSHA256(result)
        if norm then return norm end
    end

    ok, result = pcall(function()
        return crypto and crypto.sha256 and crypto.sha256(data)
    end)
    if ok and result and result ~= "" then
        local norm = normaliseSHA256(result)
        if norm then return norm end
    end

    return nil
end

local function sha256(data)
    local b = sha256_bytes(data)
    if not b then return "" end
    return bytes_to_hex(b)
end

local function hmac_sha256(key, message)
    local block_size = 64
    local keyBytes
    if #key > block_size then
        keyBytes = sha256_bytes(key)
        if not keyBytes then return "" end
    else
        keyBytes = key
    end
    while #keyBytes < block_size do keyBytes = keyBytes .. "\0" end

    local ipad, opad = {}, {}
    for i = 1, block_size do
        local b = string.byte(keyBytes, i)
        ipad[i] = string.char(bit32.bxor(b, 0x36))
        opad[i] = string.char(bit32.bxor(b, 0x5c))
    end

    local innerHash = sha256_bytes(table.concat(ipad) .. message)
    if not innerHash then return "" end
    return sha256(table.concat(opad) .. innerHash)
end

