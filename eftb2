-- helpers (reuse existing Hub functions where possible)
function Hub.getHRP()
    local c = LocalPlayer and LocalPlayer.Character
    return c and c:FindFirstChild("HumanoidRootPart")
end

function Hub.getHumanoid()
    local c = LocalPlayer and LocalPlayer.Character
    return c and c:FindFirstChildOfClass("Humanoid")
end

function Hub.isAlive()
    local c = LocalPlayer.Character
    if not c then return false end
    local h = c:FindFirstChildOfClass("Humanoid")
    return h and h.Health > 0
end

function Hub.countBrainrotsCarried()
    local count = 0
    local folder = Workspace:FindFirstChild(LocalPlayer.Name)
    if folder then
        for _, child in pairs(folder:GetChildren()) do
            if child.Name == "RenderedBrainrot" then count = count + 1 end
        end
    end
    return count
end

function Hub.unequipAll()
    pcall(function()
        local c = LocalPlayer.Character
        if not c then return end
        local bp = LocalPlayer:FindFirstChild("Backpack")
        if not bp then return end
        for _, tool in pairs(c:GetChildren()) do
            if tool:IsA("Tool") then tool.Parent = bp end
        end
    end)
end

function Hub.enableAntiRagdoll()
    local c = LocalPlayer.Character
    if not c then return end
    local hrp = c:FindFirstChild("HumanoidRootPart")
    local hum = c:FindFirstChildOfClass("Humanoid")
    if not hrp or not hum then return end
    pcall(function()
        hum.PlatformStand = true
        hum.AutoRotate    = false
        hum.WalkSpeed     = 0
        hum.JumpPower     = 0
        hum.MaxSlopeAngle = 0
        hum.UseJumpPower  = false
        if Hub.depositBodyVelocity then
            pcall(function() Hub.depositBodyVelocity:Destroy() end)
            Hub.depositBodyVelocity = nil
        end
        Hub.depositBodyVelocity = Instance.new("BodyVelocity")
        Hub.depositBodyVelocity.Velocity = Vector3.new(0, 0, 0)
        Hub.depositBodyVelocity.MaxForce = Vector3.new(9e9, 9e9, 9e9)
        Hub.depositBodyVelocity.P        = 1000000
        Hub.depositBodyVelocity.Parent   = hrp
        if not Hub.depositOriginalGravity then Hub.depositOriginalGravity = Workspace.Gravity end
        Workspace.Gravity = 0
        hrp.CFrame = CFrame.new(hrp.Position.X, Hub.TWEEN_Y, hrp.Position.Z)
    end)
end

function Hub.disableAntiRagdoll()
    pcall(function()
        local hum = Hub.getHumanoid()
        if hum then
            hum.PlatformStand = false
            hum.AutoRotate    = true
            hum.WalkSpeed     = 16
            hum.JumpPower     = 50
            hum.MaxSlopeAngle = 89
            hum.UseJumpPower  = true
        end
        if Hub.depositBodyVelocity then
            pcall(function() Hub.depositBodyVelocity:Destroy() end)
            Hub.depositBodyVelocity = nil
        end
        if Hub.depositOriginalGravity then
            Workspace.Gravity = Hub.depositOriginalGravity
            Hub.depositOriginalGravity = nil
        end
    end)
end

function Hub.stopTween()
    if Hub.depositCurrentTween then
        pcall(function() Hub.depositCurrentTween:Cancel() end)
        Hub.depositCurrentTween = nil
    end
    Hub.depositIsTweening = false
end

function Hub.goUnderground()
    local hrp = Hub.getHRP()
    if not hrp then return false end
    Hub.enableAntiRagdoll()
    hrp.CFrame = CFrame.new(hrp.Position.X, Hub.TWEEN_Y, hrp.Position.Z)
    return true
end

function Hub.tweenUndergroundWithCallback(targetPos, triggerDist, onInRange)
    local hrp = Hub.getHRP()
    if not hrp then return false end
    if math.abs(hrp.Position.Y - Hub.TWEEN_Y) > 0.1 then
        hrp.CFrame = CFrame.new(hrp.Position.X, Hub.TWEEN_Y, hrp.Position.Z)
        task.wait()
    end
    local targetCFrame = CFrame.new(targetPos.X, Hub.TWEEN_Y, targetPos.Z)
    local dist = (Vector3.new(hrp.Position.X, 0, hrp.Position.Z) - Vector3.new(targetPos.X, 0, targetPos.Z)).Magnitude
    if dist < 5 then
        hrp.CFrame = targetCFrame
        if onInRange then pcall(onInRange, hrp) end
        return Hub.isAlive()
    end
    Hub.stopTween()
    Hub.depositIsTweening = true
    local tweenTime = math.clamp(dist / Hub.depositTweenSpeed, 0.1, 10)
    local tweenInfo = TweenInfo.new(tweenTime, Enum.EasingStyle.Linear, Enum.EasingDirection.Out, 0, false, 0)
    Hub.depositCurrentTween = TweenService:Create(hrp, tweenInfo, {CFrame = targetCFrame})
    Hub.depositCurrentTween:Play()
    local lockConn
    lockConn = RunService.Heartbeat:Connect(function()
        if not Hub.depositIsTweening or not hrp or not hrp.Parent then lockConn:Disconnect(); return end
        hrp.CFrame = CFrame.new(hrp.Position.X, Hub.TWEEN_Y, hrp.Position.Z)
    end)
    local triggered = false
    if triggerDist and onInRange then
        task.spawn(function()
            while Hub.depositIsTweening do
                local h = Hub.getHRP()
                if not h then break end
                local dx = h.Position.X - targetPos.X
                local dz = h.Position.Z - targetPos.Z
                if math.sqrt(dx*dx + dz*dz) <= triggerDist and not triggered then
                    triggered = true
                    pcall(onInRange, h)
                    break
                end
                task.wait(0.03)
            end
        end)
    end
    Hub.depositCurrentTween.Completed:Wait()
    lockConn:Disconnect()
    Hub.depositIsTweening = false
    if not triggered and onInRange then pcall(onInRange, hrp) end
    return Hub.isAlive()
end

function Hub.tweenUnderground(targetPos)
    return Hub.tweenUndergroundWithCallback(targetPos, nil, nil)
end

function Hub.getMachinePrompt()
    local prompt = nil
    pcall(function()
        local pot = Workspace:FindFirstChild("PotOfGold")
        if not pot then return end
        prompt = pot:FindFirstChildWhichIsA("ProximityPrompt", true)
    end)
    return prompt
end

function Hub.getMachinePosition()
    local pos = nil
    pcall(function()
        local pot = Workspace:FindFirstChild("PotOfGold")
        if not pot then return end
        local prompt = pot:FindFirstChildWhichIsA("ProximityPrompt", true)
        if prompt then
            local obj = prompt.Parent
            while obj and obj ~= pot do
                if obj:IsA("BasePart") then pos = obj.Position; return end
                obj = obj.Parent
            end
        end
        if pot:IsA("Model") and pot.PrimaryPart then
            pos = pot.PrimaryPart.Position
        else
            local part = pot:FindFirstChildWhichIsA("BasePart", true)
            if part then pos = part.Position end
        end
    end)
    return pos
end

function Hub.isEventActive()
    return Workspace:FindFirstChild("PotOfGold") ~= nil
end

function Hub.hookConfirm()
    pcall(function()
        local shared = ReplicatedStorage:FindFirstChild("Shared")
        if not shared then return end
        local remotes = shared:FindFirstChild("Remotes")
        if not remotes then return end
        local rf = remotes:FindFirstChild("RainbowSacrificeConfirm")
        if rf and rf:IsA("RemoteFunction") then
            rf.OnClientInvoke = function() return true end
        end
        for _, child in pairs(remotes:GetDescendants()) do
            if child:IsA("RemoteFunction") and (
                child.Name:lower():find("sacrifice") or
                child.Name:lower():find("rainbow") or
                child.Name:lower():find("confirm")
            ) then
                child.OnClientInvoke = function() return true end
            end
        end
    end)
end

function Hub.getAllBrainrots()
    local list = {}
    local folder = Workspace:FindFirstChild("ActiveBrainrots")
    if folder then
        for _, rarityFolder in pairs(folder:GetChildren()) do
            if rarityFolder:IsA("Folder") then
                for _, brainrot in pairs(rarityFolder:GetChildren()) do
                    if brainrot:IsA("Model") and brainrot:FindFirstChild("Root") then
                        table.insert(list, brainrot)
                    end
                end
            end
        end
    end
    local debris = Workspace:FindFirstChild("Debris")
    if debris then
        for _, child in pairs(debris:GetChildren()) do
            if child:FindFirstChildWhichIsA("ProximityPrompt", true) then
                table.insert(list, child)
            end
        end
    end
    return list
end

function Hub.getDebrisBrainrots()
    local list = {}
    local debris = Workspace:FindFirstChild("Debris")
    if debris then
        for _, child in pairs(debris:GetChildren()) do
            if child:FindFirstChildWhichIsA("ProximityPrompt", true) then
                table.insert(list, child)
            end
        end
    end
    return list
end

function Hub.getRarity(brainrot)
    local rarity = nil
    pcall(function()
        rarity = brainrot:GetAttribute("Rarity")
        if not rarity then
            for _, child in pairs(brainrot:GetChildren()) do
                if child.Name == "RenderedBrainrot" then rarity = child:GetAttribute("Rarity"); break end
            end
        end
        if not rarity and brainrot.Parent then rarity = brainrot.Parent.Name end
    end)
    return rarity
end

function Hub.getMutation(brainrot)
    local mutation = nil
    pcall(function()
        mutation = brainrot:GetAttribute("Mutation")
        if not mutation then
            for _, child in pairs(brainrot:GetChildren()) do
                if child.Name == "RenderedBrainrot" then mutation = child:GetAttribute("Mutation"); break end
            end
        end
    end)
    return mutation and tostring(mutation) or "None"
end

function Hub.getRarityRank(brainrot)
    local rarity = Hub.getRarity(brainrot)
    return rarity and (Hub.RARITY_ORDER[rarity] or 0) or 0
end

function Hub.findBestBrainrot(alreadyCollected)
    local hrp = Hub.getHRP()
    if not hrp then return nil end
    local playerPos = hrp.Position
    local all = Hub.getAllBrainrots()
    local candidates = {}
    for _, b in pairs(all) do
        if not alreadyCollected or not alreadyCollected[b] then
            table.insert(candidates, b)
        end
    end
    if #candidates == 0 then return nil end

    for _, b in pairs(candidates) do
        if Hub.getMutation(b) == "Shamrock" then return b end
    end

    if Hub.autoDepositBest then
        for _, b in pairs(candidates) do
            local rarity = Hub.getRarity(b)
            if rarity and Hub.PRIORITY_RARITIES[rarity] and Hub.getMutation(b) == "Shamrock" then return b end
        end
        for _, b in pairs(candidates) do
            local rarity = Hub.getRarity(b)
            if rarity and Hub.PRIORITY_RARITIES[rarity] then return b end
        end
        local best, bestRank = nil, -1
        for _, b in pairs(candidates) do
            local rank = Hub.getRarityRank(b)
            if rank > bestRank then bestRank = rank; best = b end
        end
        return best
    end

    local closest, closestDist = nil, math.huge
    for _, b in pairs(candidates) do
        local part = nil
        if b:IsA("Model") then
            part = b.PrimaryPart or b:FindFirstChild("Root") or b:FindFirstChildWhichIsA("BasePart")
        else
            part = b
        end
        if part then
            local d = (part.Position - playerPos).Magnitude
            if d < closestDist then closestDist = d; closest = b end
        end
    end
    return closest
end

function Hub.collectBrainrot(brainrot)
    if Hub.depositIsCollecting then Hub.depositIsCollecting = false; task.wait(0.03) end
    if not brainrot or not brainrot.Parent then return false end

    local targetPart
    local prompt

    if brainrot:IsA("Model") then
        local root = brainrot:FindFirstChild("Root")
        if root then
            targetPart = root
        else
            targetPart = brainrot.PrimaryPart or brainrot:FindFirstChildWhichIsA("BasePart")
        end
        prompt = brainrot:FindFirstChildWhichIsA("ProximityPrompt", true)
    elseif brainrot:IsA("BasePart") then
        targetPart = brainrot
        prompt = brainrot:FindFirstChildWhichIsA("ProximityPrompt")
    end

    if not targetPart or not prompt then return false end
    if not prompt:IsA("ProximityPrompt") then return false end

    Hub.depositIsCollecting = true
    local countBefore = Hub.countBrainrotsCarried()
    local success = false

    pcall(function()
        if not Hub.isAlive() then return end
        Hub.goUnderground()
        if not brainrot.Parent or not brainrot:IsDescendantOf(Workspace) then return end

        local function firePrompt()
            for i = 1, 8 do
                if not prompt.Parent then break end
                fireproximityprompt(prompt)
                task.wait(0.02)
            end
        end

        Hub.tweenUndergroundWithCallback(targetPart.Position, Hub.BRAINROT_TRIGGER_DIST, firePrompt)

        if not brainrot.Parent or not brainrot:IsDescendantOf(Workspace) then return end
        if not targetPart.Parent then return end

        if Hub.countBrainrotsCarried() > countBefore then
            success = true
            return
        end

        task.wait(0.1)
        if prompt and prompt:IsA("ProximityPrompt") then
            for i = 1, 8 do
                if not prompt.Parent then break end
                fireproximityprompt(prompt)
                task.wait(0.02)
            end
        end

        task.wait(0.1)
        if Hub.countBrainrotsCarried() <= countBefore then
            if prompt and prompt:IsA("ProximityPrompt") and prompt.Parent then
                for i = 1, 8 do
                    if not prompt.Parent then break end
                    fireproximityprompt(prompt)
                    task.wait(0.02)
                end
            end
            task.wait(0.15)
        end

        if Hub.countBrainrotsCarried() > countBefore then success = true end
    end)

    Hub.depositIsCollecting = false
    return success
end

function Hub.depositAtMachine()
    if Hub.depositIsDepositing then Hub.depositIsDepositing = false; task.wait(0.03) end
    if Hub.countBrainrotsCarried() == 0 then return false end
    Hub.depositIsDepositing = true
    local success = false
    pcall(function()
        if not Hub.isAlive() then return end

        local machinePos = Hub.getMachinePosition()
        if not machinePos then return end
        local carrying = Hub.countBrainrotsCarried()

        Hub.goUnderground()
        Hub.tweenUndergroundWithCallback(
            Vector3.new(machinePos.X, Hub.TWEEN_Y, machinePos.Z),
            Hub.MACHINE_TRIGGER_DIST,
            nil
        )
        if not Hub.isAlive() then return end

        local hrp = Hub.getHRP()
        if not hrp then return end

        if Hub.depositBodyVelocity then
            pcall(function() Hub.depositBodyVelocity:Destroy() end)
            Hub.depositBodyVelocity = nil
        end
        local riseDist = math.abs(machinePos.Y - Hub.TWEEN_Y)
        local riseTime = math.clamp(riseDist / 80, 0.05, 1.5)
        local riseTween = TweenService:Create(hrp, TweenInfo.new(riseTime, Enum.EasingStyle.Linear), {
            CFrame = CFrame.new(machinePos.X, machinePos.Y, machinePos.Z)
        })
        riseTween:Play()
        riseTween.Completed:Wait()

        local prompt = Hub.getMachinePrompt()
        if prompt and prompt:IsA("ProximityPrompt") then
            for i = 1, carrying do
                if not prompt.Parent then break end
                fireproximityprompt(prompt); task.wait(0.04)
                fireproximityprompt(prompt); task.wait(0.08)
            end
        end
        task.wait(0.2)

        hrp = Hub.getHRP()
        if hrp then
            hrp.CFrame = CFrame.new(machinePos.X, Hub.TWEEN_Y, machinePos.Z)
        end
        Hub.enableAntiRagdoll()

        success = true
    end)
    Hub.depositIsDepositing = false
    return success
end

