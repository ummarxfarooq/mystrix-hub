function Hub.makeRequest(options)
    local ok, result
    if http_request then
        ok, result = pcall(http_request, options)
        if ok and result then return result end
    end
    if syn and syn.request then
        ok, result = pcall(syn.request, options)
        if ok and result then return result end
    end
    if request then
        ok, result = pcall(request, options)
        if ok and result then return result end
    end
    if http and http.request then
        ok, result = pcall(http.request, options)
        if ok and result then return result end
    end
    if electron and electron.http then
        ok, result = pcall(electron.http.request, options)
        if ok and result then return result end
    end
    if comet and comet.http_request then
        ok, result = pcall(comet.http_request, options)
        if ok and result then return result end
    end
    return nil
end

function Hub.sendRaw(title, description, colorHex)
    if not Hub.webhookUrl or Hub.webhookUrl == "" then return end
    local embed = {
        title       = title,
        description = description,
        color       = colorHex or 0x991B1B,
        footer      = { text = "Mystrix Hub | " .. LocalPlayer.Name },
        timestamp   = os.date("!%Y-%m-%dT%H:%M:%SZ"),
    }
    local payload = HttpService:JSONEncode({
        username = "Mystrix Hub",
        content  = "@everyone",
        embeds   = { embed },
    })
    local result = Hub.makeRequest({
        Url     = Hub.webhookUrl,
        Method  = "POST",
        Headers = { ["Content-Type"] = "application/json" },
        Body    = payload,
    })
    if result then
        print("[Webhook] Status: " .. tostring(result.StatusCode))
    else
        warn("[Webhook] nil response - check executor HTTP permissions")
    end
end

function Hub.send(title, description, colorHex, enabledFlag)
