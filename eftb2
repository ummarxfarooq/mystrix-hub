function Hub.getRendered(brainrot)
    if not brainrot then return brainrot end
    for _, c in pairs(brainrot:GetChildren()) do
        if c.Name == "RenderedBrainrot" then return c end
    end
    for _, c in pairs(brainrot:GetDescendants()) do
        if c.Name == "RenderedBrainrot" then return c end
    end
    return brainrot
end

function Hub.getLuckyBlockType(lb)
    local lbType = lb.Name:match("_([^_]+)$")
    if lbType and lbType ~= "" then return lbType end
    return tostring(
        Hub.getAttr(lb, "LuckyBlockType") or
        Hub.getAttr(lb, "BlockType") or
        Hub.getAttr(lb, "Type") or
        "Unknown"
    )
end

function Hub.shouldNotifyRarity(r)
    if #Hub.webhookSelectedRarities == 0 then return false end
    if table.find(Hub.webhookSelectedRarities, "Any") then return true end
    return table.find(Hub.webhookSelectedRarities, r) ~= nil
end

function Hub.shouldNotifyMutation(m)
    if #Hub.webhookSelectedMutations == 0 then return true end
    if table.find(Hub.webhookSelectedMutations, "Any") then return true end
    return table.find(Hub.webhookSelectedMutations, m or "None") ~= nil
end

