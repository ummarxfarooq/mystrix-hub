-- ========================================
-- FORMAT HELPERS
-- ========================================
local function formatTimeRemaining(seconds)
    if seconds <= 0 then return "Expired" end
    local days = math.floor(seconds / 86400)
    local hours = math.floor((seconds % 86400) / 3600)
    local minutes = math.floor((seconds % 3600) / 60)
    if days > 0 then return days .. " day" .. (days > 1 and "s" or "")
    elseif hours > 0 then return hours .. " hour" .. (hours > 1 and "s" or "")
    elseif minutes > 0 then return minutes .. " minute" .. (minutes > 1 and "s" or "")
    else return "Less than a minute" end
end

local function formatExpiryDate(isoDate)
    if not isoDate then return nil end
    local ok, expiryDate = pcall(function() return DateTime.fromIsoDate(isoDate) end)
    if ok and expiryDate then
        local t = os.date("*t", expiryDate.UnixTimestamp)
        return string.format("%02d/%02d/%d %02d:%02d", t.month, t.day, t.year, t.hour, t.min)
    end
    return nil
end

local function updateExpiryDisplay(frame, validUntil, expiresIn)
    if not frame then return end
    local expiryLabel = frame:FindFirstChild("ExpiryLabel")
    if not expiryLabel then return end
    if validUntil then
        local dateStr = formatExpiryDate(validUntil)
        if dateStr then
            local ok, expiryDate = pcall(function() return DateTime.fromIsoDate(validUntil) end)
            if ok and expiryDate then
                local secondsLeft = expiryDate.UnixTimestamp - os.time()
                expiryLabel.Text = "Expires: " .. dateStr .. " (" .. formatTimeRemaining(secondsLeft) .. " left)"
                expiryLabel.TextColor3 = Color3.fromRGB(100, 255, 100)
                expiryLabel.Visible = true
                return
            end
        end
    elseif expiresIn then
        expiryLabel.Text = "Time remaining: " .. formatTimeRemaining(expiresIn)
        expiryLabel.TextColor3 = Color3.fromRGB(100, 255, 100)
        expiryLabel.Visible = true
        return
    end
    expiryLabel.Visible = false
end

local function getFriendlyErrorMessage(errorCode, extraInfo)
    local messages = {
        ["INVALID_KEY"]    = "The key you entered is invalid. Please check and try again.",
        ["EXPIRED"]        = "This key has expired. Please get a new key from our Discord.",
        ["REVOKED"]        = "This key has been revoked. Please contact support.",
        ["NOT_FOUND"]      = "Key not found in our system. Did you enter it correctly?",
        ["HWID_REQUIRED"]  = "HWID required. Please restart the game.",
        ["HWID_MISMATCH"]  = "This key is linked to another device.\n\nVisit our Discord to reset your HWID.",
        ["NETWORK_ERROR"]  = "Network error. Check your internet connection and try again.",
        ["TIMESTAMP_ERROR"]= "Time sync error. Please check your device's date/time settings.",
        ["RATE_LIMITED"]   = "Too many attempts. Please wait a few minutes and try again."
    }
    if errorCode == "HWID_MISMATCH" and extraInfo and extraInfo.hwidReset then
        return "HWID Reset Detected!\n\nYour key is still valid. Click Verify again to continue."
    end
    return messages[errorCode] or "Unknown error. Please contact support."
end

