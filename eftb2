    local function sacTweenUndergroundWithCallback(targetPos, triggerDist, onInRange)
        local hrp = sacGetHRP()
        if not hrp then return false end
        if math.abs(hrp.Position.Y - SACRIFICE_TWEEN_Y) > 0.1 then
            hrp.CFrame = CFrame.new(hrp.Position.X, SACRIFICE_TWEEN_Y, hrp.Position.Z)
            task.wait()
        end
        local targetCFrame = CFrame.new(targetPos.X, SACRIFICE_TWEEN_Y, targetPos.Z)
        local currentPos = Vector3.new(hrp.Position.X, 0, hrp.Position.Z)
        local targetPos2D = Vector3.new(targetPos.X, 0, targetPos.Z)
        local distance = (targetPos2D - currentPos).Magnitude
        if distance < 5 then
            hrp.CFrame = targetCFrame
            if onInRange then pcall(onInRange, hrp) end
            return sacIsAlive()
        end
        sacStopTween()
        sacrificeIsTweening = true
        local tweenTime = math.clamp(distance / sacrificeTweenSpeed, 0.1, 10)
        local tweenInfo = TweenInfo.new(tweenTime, Enum.EasingStyle.Linear, Enum.EasingDirection.Out, 0, false, 0)
        sacrificeCurrentTween = TweenService:Create(hrp, tweenInfo, {CFrame = targetCFrame})
        sacrificeCurrentTween:Play()
        local lockConnection
        lockConnection = RunService.Heartbeat:Connect(function()
            if not sacrificeIsTweening or not hrp or not hrp.Parent then
                lockConnection:Disconnect()
                return
            end
            hrp.CFrame = CFrame.new(hrp.Position.X, SACRIFICE_TWEEN_Y, hrp.Position.Z)
        end)
        local triggered = false
        if triggerDist and onInRange then
            task.spawn(function()
                while sacrificeIsTweening do
                    local h = sacGetHRP()
                    if not h then break end
                    local dx = h.Position.X - targetPos.X
                    local dz = h.Position.Z - targetPos.Z
                    if math.sqrt(dx*dx + dz*dz) <= triggerDist and not triggered then
                        triggered = true
                        pcall(onInRange, h)
                        break
                    end
                    task.wait(0.03)
                end
            end)
        end
        sacrificeCurrentTween.Completed:Wait()
        lockConnection:Disconnect()
        sacrificeIsTweening = false
        if not triggered and onInRange then
            pcall(onInRange, hrp)
        end
        return sacIsAlive()
    end

