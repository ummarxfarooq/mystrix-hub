    local function collectBrainrot(brainrot)
        if isCollecting then return false end
        if not brainrot or not brainrot.Parent then return false end
        local root = brainrot:FindFirstChild("Root")
        if not root then return false end
        isCollecting         = true
        currentTargetBrainrot = brainrot
        local success = false
        pcall(function()
            if not isPlayerAlive() then return end
            goUnderground()
            local prompt = root:FindFirstChild("TakePrompt")
            tweenUndergroundWithCallback(root.Position, BRAINROT_TRIGGER_DIST, function()
                if prompt and prompt:IsA("ProximityPrompt") and prompt.Parent then
                    for i = 1, 8 do
                        if not prompt.Parent then break end
                        fireproximityprompt(prompt)
                        task.wait(0.02)
                    end
                end
            end)
            if not brainrot.Parent then return end
            task.wait(0.1)
            if hasBrainrotEquipped() then
                collectedBrainrot     = brainrot
                hasBrainrotForDeposit = true
                currentTargetBrainrot = nil
                lastBrainrotPosition  = nil
                stuckCounter          = 0
                success               = true
                return
            end
            if prompt and prompt:IsA("ProximityPrompt") then
                for i = 1, 8 do fireproximityprompt(prompt); task.wait(0.02) end
            end
            task.wait(0.2)
            if not hasBrainrotEquipped() then
                if prompt and prompt:IsA("ProximityPrompt") then
                    for i = 1, 8 do fireproximityprompt(prompt); task.wait(0.02) end
                end
                task.wait(0.3)
            end
            if hasBrainrotEquipped() then
                collectedBrainrot     = brainrot
                hasBrainrotForDeposit = true
                currentTargetBrainrot = nil
                lastBrainrotPosition  = nil
                stuckCounter          = 0
                success               = true
            else
                success = false
            end
        end)
        isCollecting = false
        if not success then currentTargetBrainrot = nil end
        return success
    end

    local function depositAtTower()
        if isDepositing then return false end
        if not hasBrainrotForDeposit and not hasBrainrotEquipped() then return false end
        isDepositing = true
        local success = false
        pcall(function()
            if not isPlayerAlive() then return end
            refreshTowerPosition()
            goUnderground()
            if not tweenUnderground(towerPosition) then return end
            task.wait(0.2)
            if towerPrompt and towerPrompt:IsA("ProximityPrompt") then
                fireproximityprompt(towerPrompt)
            end
            task.wait(0.3)
            if not hasBrainrotEquipped() then
                hasBrainrotForDeposit = false
                collectedBrainrot     = nil
                justDeposited         = true
                depositTime           = os.time()
            end
            task.wait(0.2)
            updateDepositCountFromHUD()
            success = true
        end)
        isDepositing = false
        return success
    end

