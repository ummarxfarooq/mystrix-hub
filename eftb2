            if isBrainrotOnOurSide(b) then
                if not alreadyCollected or not alreadyCollected[b] then
                    table.insert(ourSide, b)
                end
            end
        end

        if #ourSide == 0 then return nil end

        if not sacrificeBestEnabled then
            local closest, closestDist = nil, math.huge
            for _, b in pairs(ourSide) do
                local root = b:FindFirstChild("Root")
                if root then
                    local dx = root.Position.X - playerPos.X
                    local dz = root.Position.Z - playerPos.Z
                    local d = math.sqrt(dx*dx + dz*dz)
                    if d < closestDist then closestDist = d; closest = b end
                end
            end
            return closest
        end

        for _, b in pairs(ourSide) do
            local rarity = getBrainrotRarity(b)
            if rarity and PRIORITY_RARITIES[rarity] and hasTeamMutation(b) then
                return b
            end
        end

        local best, bestRank = nil, -1
        for _, b in pairs(ourSide) do
            local rarity = getBrainrotRarity(b)
            if rarity and PRIORITY_RARITIES[rarity] then
                local rank = getBrainrotRarityRank(b)
                if rank > bestRank then
                    bestRank = rank
                    best = b
                end
            end
        end
        return best
    end

    local function findPreEventBrainrot(alreadyCollected)
        local all = getAllActiveBrainrots()
        local filtered = {}
        for _, b in pairs(all) do
            if not alreadyCollected or not alreadyCollected[b] then
                local rarity = getBrainrotRarity(b)
                if rarity and PRIORITY_RARITIES[rarity] then
                    table.insert(filtered, b)
                end
            end
        end
        if #filtered == 0 then return nil end
        for _, b in pairs(filtered) do
            if hasTeamMutation(b) then return b end
        end
        local best, bestRank = nil, -1
        for _, b in pairs(filtered) do
            local rank = getBrainrotRarityRank(b)
            if rank > bestRank then bestRank = rank; best = b end
        end
        return best
    end

    local function sacCollectBrainrot(brainrot)
        if sacrificeIsCollecting then
            sacrificeIsCollecting = false
            task.wait(0.03)
        end
        if not brainrot or not brainrot.Parent then return false end
        local root = brainrot:FindFirstChild("Root")
        if not root then return false end
        sacrificeIsCollecting = true
        local countBefore = sacCountBrainrotsCarried()
        local success = false
        pcall(function()
            if not sacIsAlive() then return end
            sacGoUnderground()
            if not brainrot.Parent or not brainrot:IsDescendantOf(Workspace) then return end
            local prompt = root:FindFirstChild("TakePrompt")
            local function fireOnClose()
                if not prompt or not prompt:IsA("ProximityPrompt") then return end
                for i = 1, 8 do
                    if not prompt.Parent then break end
                    fireproximityprompt(prompt)
                    task.wait(0.02)
                end
            end
            sacTweenUndergroundWithCallback(root.Position, SAC_BRAINROT_TRIGGER, function()
                fireOnClose()
            end)
            if not brainrot.Parent or not brainrot:IsDescendantOf(Workspace) then return end
            if not root.Parent then return end
            if sacCountBrainrotsCarried() > countBefore then
                success = true
                return
            end
            task.wait(0.1)
            if prompt and prompt:IsA("ProximityPrompt") then
                for i = 1, 8 do
                    if not prompt.Parent then break end
                    fireproximityprompt(prompt)
                    task.wait(0.02)
                end
            end
            task.wait(0.1)
            if sacCountBrainrotsCarried() <= countBefore then
                if prompt and prompt:IsA("ProximityPrompt") and prompt.Parent then
                    for i = 1, 8 do
                        if not prompt.Parent then break end
                        fireproximityprompt(prompt)
                        task.wait(0.02)
                    end
                end
                task.wait(0.15)
            end
            if sacCountBrainrotsCarried() > countBefore then success = true end
        end)
        sacrificeIsCollecting = false
        return success
    end

    local function sacDepositAtMachine()
        if sacrificeIsDepositing then
            sacrificeIsDepositing = false
            task.wait(0.03)
        end
        if sacCountBrainrotsCarried() == 0 then return false end
        sacrificeIsDepositing = true
        local success = false
        pcall(function()
            if not sacIsAlive() then return end
            sacGoUnderground()
            local carrying = sacCountBrainrotsCarried()
            local promptFired = 0
            local function fireDeposits()
                local prompt = getMachinePrompt()
                if not prompt or not prompt:IsA("ProximityPrompt") then return end
                for i = 1, carrying do
                    if not prompt.Parent then break end
                    fireproximityprompt(prompt)
                    task.wait(0.04)
                    fireproximityprompt(prompt)
                    task.wait(0.08)
                    promptFired = promptFired + 1
                end
            end
            sacTweenUndergroundWithCallback(MACHINE_POSITION, MACHINE_TRIGGER_DIST, function()
                fireDeposits()
            end)
            if promptFired == 0 then
                fireDeposits()
            end
            task.wait(0.1)
            success = true
        end)
        sacrificeIsDepositing = false
        return success
    end

    -- Pre-event helpers
    local function sacWaitForRespawn()
        while sacrificeEnabled do
            if sacIsAlive() then break end
            task.wait(0.3)
        end
        task.wait(0.5)
        if sacrificeEnabled then sacGoUnderground() end
    end

    local function runPreEventCollect()
        local alreadyCollected = {}
        local startTime = os.time()
        while sacrificeEnabled and preEventActive do
            if os.time() - startTime > 55 then break end
            if sacCountBrainrotsCarried() >= sacrificeCarryLimit then break end
            if not sacIsAlive() then
                sacWaitForRespawn()
                alreadyCollected = {}
                continue
            end
            local timeLeft = getTimeUntilFireAndIce()
            if not timeLeft or timeLeft <= 0 then break end
            local brainrot = findPreEventBrainrot(alreadyCollected)
            if not brainrot then
                task.wait(0.5)
                continue
            end
            sacCollectBrainrot(brainrot)
            alreadyCollected[brainrot] = true
            task.wait(0.05)
        end
    end

    local function waitForMachineAndDeposit()
        if sacCountBrainrotsCarried() == 0 then return end
        local waitStart = os.time()

        local hrp = sacGetHRP()
        if hrp then
            sacEnableAntiRagdoll()
            local waitCFrame = CFrame.new(PRE_EVENT_WAIT_POS.X, SACRIFICE_TWEEN_Y, PRE_EVENT_WAIT_POS.Z)
            local currentPos = hrp.Position
            local distance = (Vector3.new(waitCFrame.X, 0, waitCFrame.Z) - Vector3.new(currentPos.X, 0, currentPos.Z)).Magnitude
            if distance > 1 then
                local tweenTime = math.clamp(distance / sacrificeTweenSpeed, 0.1, 5)
                local tweenInfo = TweenInfo.new(tweenTime, Enum.EasingStyle.Linear, Enum.EasingDirection.Out)
                local tween = TweenService:Create(hrp, tweenInfo, {CFrame = waitCFrame})
                tween:Play()
                tween.Completed:Wait()
            else
                hrp.CFrame = waitCFrame
            end
        end

        while sacrificeEnabled and os.time() - waitStart < 60 do
            if getSacrificeMachine() then
                hookSacrificeConfirm()
                sacDepositAtMachine()
                return
            end
            if not sacIsAlive() then
                sacWaitForRespawn()
                local newHrp = sacGetHRP()
                if newHrp then
                    sacEnableAntiRagdoll()
                    newHrp.CFrame = CFrame.new(PRE_EVENT_WAIT_POS.X, SACRIFICE_TWEEN_Y, PRE_EVENT_WAIT_POS.Z)
                end
            else
                sacEnableAntiRagdoll()
                local currentHrp = sacGetHRP()
                if currentHrp then
                    local distFromWait = (Vector3.new(currentHrp.Position.X, 0, currentHrp.Position.Z) -
                                         Vector3.new(PRE_EVENT_WAIT_POS.X, 0, PRE_EVENT_WAIT_POS.Z)).Magnitude
                    if distFromWait > 3 then
                        currentHrp.CFrame = CFrame.new(PRE_EVENT_WAIT_POS.X, SACRIFICE_TWEEN_Y, PRE_EVENT_WAIT_POS.Z)
                    end
                end
            end
            task.wait(0.5)
        end
    end

    -- Main loop
    local function startSacrificeLoop()
        if sacrificeConnection then
            task.cancel(sacrificeConnection)
            sacrificeConnection = nil
        end

        sacrificeConnection = task.spawn(function()
            while sacrificeEnabled do
                local timeUntilEvent = getTimeUntilFireAndIce()
                if timeUntilEvent and timeUntilEvent > 0 and timeUntilEvent <= 60 then
                    preEventActive = true
                    runPreEventCollect()
                    preEventActive = false
                    waitForMachineAndDeposit()
                end

                sacrificeTeam = nil
                local teamWaitCount = 0
                while sacrificeEnabled and not sacrificeTeam do
                    sacrificeTeam = getSacrificeTeam()
                    if sacrificeTeam then break end
                    teamWaitCount = teamWaitCount + 1
                    local t2 = getTimeUntilFireAndIce()
                    if t2 and t2 > 0 and t2 <= 60 and not preEventActive then
                        preEventActive = true
                        runPreEventCollect()
                        preEventActive = false
                        waitForMachineAndDeposit()
                    end
                    task.wait(2)
                end
                if not sacrificeEnabled then break end

                while sacrificeEnabled and not getSacrificeMachine() do
                    sacUnequipAll()
                    task.wait(2)
                end
                if not sacrificeEnabled then break end

                hookSacrificeConfirm()

                while sacrificeEnabled do
                    if not getSacrificeMachine() then
                        sacrificeTeam = nil
                        sacDisableAntiRagdoll()
                        break
                    end

                    local currentTeam = getSacrificeTeam()
                    if currentTeam and currentTeam ~= sacrificeTeam then
                        sacrificeTeam = currentTeam
                    end

                    sacUnequipAll()

                    if not sacIsAlive() then
                        task.wait(1)
                        continue
                    end

                    local carrying = sacCountBrainrotsCarried()

                    if sacrificeBestEnabled then
                        local target = sacrificeCarryLimit
                        if carrying >= target then
                            sacDepositAtMachine()
                        else
                            local alreadyCollected = {}
                            while sacrificeEnabled and sacCountBrainrotsCarried() < target do
                                if not getSacrificeMachine() then break end
                                if not sacIsAlive() then break end
                                local brainrot = findSacrificeBrainrot(alreadyCollected)
                                if not brainrot then
                                    task.wait(0.3)
                                    break
                                end
                                sacCollectBrainrot(brainrot)
                                alreadyCollected[brainrot] = true
                            end
                            if sacCountBrainrotsCarried() > 0 then
                                sacDepositAtMachine()
                            end
                        end
                    else
                        if carrying > 0 then
                            sacDepositAtMachine()
                        else
                            local brainrot = findSacrificeBrainrot(nil)
                            if brainrot then
                                local ok = sacCollectBrainrot(brainrot)
                                if ok then
                                    sacDepositAtMachine()
                                else
                                    task.wait(0.05)
                                end
                            else
                                task.wait(0.3)
                            end
                        end
                    end

                    task.wait(0.05)
                end

                if sacrificeEnabled and not getSacrificeMachine() then
                    task.wait(3)
                end
            end

            sacDisableAntiRagdoll()
            sacUnequipAll()
        end)
    end

    local function stopSacrifice()
        sacrificeEnabled      = false
        preEventActive        = false
        if sacrificeConnection then
            task.cancel(sacrificeConnection)
            sacrificeConnection = nil
        end
        sacStopTween()
        sacrificeIsCollecting = false
        sacrificeIsDepositing = false
        sacrificeIsTweening   = false
        sacrificeTeam         = nil
        sacDisableAntiRagdoll()
        sacUnequipAll()
    end

    -- UI
    SacrificeSection:Toggle({
        Title    = "Sacrifice Best Brainrots",
        Flag     = "SacrificeBestToggle",
        Value    = false,
        Callback = function(value)
            sacrificeBestEnabled = value
        end
    })

    SacrificeSection:Slider({
        Title    = "Carry Limit",
        Flag     = "SacrificeCarryLimitSlider",
        Value    = {Min = 1, Max = 6, Default = 1, Increment = 1},
        Callback = function(value)
            sacrificeCarryLimit = value
        end
    })

    Hub.UI.SacrificeAutoToggle = SacrificeSection:Toggle({
        Title    = "Auto Sacrifice",
        Flag     = "SacrificeAutoToggle",
        Value    = false,
        Callback = function(value)
            if value then
                sacrificeEnabled = true
                hookSacrificeConfirm()
                startSacrificeLoop()
                WindUI:Notify({
                    Title    = "Auto Sacrifice Started",
                    Content  = "Starting!",
                    Duration = 3,
                    Icon     = "flame"
                })
            else
                stopSacrifice()
                WindUI:Notify({
                    Title    = "Auto Sacrifice Stopped",
                    Duration = 3,
                    Icon     = "stop"
                })
            end
        end
    })

    LocalPlayer.CharacterAdded:Connect(function()
        if sacrificeEnabled then
            sacrificeIsCollecting = false
            sacrificeIsDepositing = false
            sacStopTween()
            sacDisableAntiRagdoll()
            task.wait(1.5)
        end
    end)
end
