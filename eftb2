function Hub.carnivalGetClownPos()
    local pos = nil
    pcall(function()
        local clown = Workspace:FindFirstChild("GameObjects")
            and Workspace.GameObjects:FindFirstChild("Enemies")
            and Workspace.GameObjects.Enemies:FindFirstChild("Carnival")
            and Workspace.GameObjects.Enemies.Carnival:FindFirstChild("NPC_CarnivalClown")
        if not clown then return end
        local hrp = clown:FindFirstChild("HumanoidRootPart")
            or clown.PrimaryPart
            or clown:FindFirstChildWhichIsA("BasePart", true)
        if hrp then pos = hrp.Position end
    end)
    return pos
end

function Hub.carnivalGetNearestPlayerPos()
    local myHrp = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
    if not myHrp then return nil end
    local myPos = myHrp.Position
    local best, bestDist = nil, math.huge
    for _, p in pairs(game:GetService("Players"):GetPlayers()) do
        if p == LocalPlayer then continue end
        local c = p.Character
        if not c then continue end
        local hrp = c:FindFirstChild("HumanoidRootPart")
        if not hrp then continue end
        local d = (hrp.Position - myPos).Magnitude
        if d < bestDist then bestDist = d; best = hrp.Position end
    end
    return best
end

function Hub.carnivalGetBestThrowTarget()
    local playerPos = Hub.carnivalHitPlayers and Hub.carnivalGetNearestPlayerPos() or nil
    local clownPos  = Hub.carnivalHitClown  and Hub.carnivalGetClownPos()         or nil
    if playerPos and clownPos then
        -- Both on — pick whichever is closer
        local myHrp = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
        if myHrp then
            local dp = (playerPos - myHrp.Position).Magnitude
            local dc = (clownPos  - myHrp.Position).Magnitude
            return dc < dp and clownPos or playerPos
        end
        return playerPos
    end
    return playerPos or clownPos
end

