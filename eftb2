-- Returns the raw CooldownContainer label text, or nil if not visible
function Hub.carnivalGetCooldownLabel()
    local label = nil
    pcall(function()
        local machine = Hub.carnivalGetMachine()
        if not machine or not machine.PrimaryPart then return end
        local billboard = machine.PrimaryPart:FindFirstChild("Billboard", true)
        if not billboard then return end
        local gui = billboard:FindFirstChildOfClass("BillboardGui")
        if not gui then return end
        local brainrotsFrame = gui:FindFirstChild("Frame"):FindFirstChild("Brainrots")
        if not brainrotsFrame then return end
        local container = brainrotsFrame:FindFirstChild("CooldownContainer")
        if container and container.Visible then
            label = container:FindFirstChild("TimeLabel")
        end
    end)
    return label
end

function Hub.carnivalGetCooldownSeconds()
    local secs = 0
    pcall(function()
        local label = Hub.carnivalGetCooldownLabel()
        if not label or not label:IsA("TextLabel") then return end
        if label.Text == "GO!" then return end
        local s = label.Text:match("(%d+)s")
        if s then secs = tonumber(s) or 0 end
    end)
    return secs
end

-- Returns true once cooldown is fully done (label says "GO!" or container hidden)
-- Also returns false immediately if machine disappears
function Hub.carnivalWaitForCooldown()
    -- Phase 1: After a combine the CooldownContainer may not be visible yet.
    -- Wait up to 5s for it to appear (become visible) to confirm cooldown started.
    local t0 = os.clock()
    local cooldownStarted = false
    while os.clock() - t0 < 5 do
        if not Hub.carnivalAutoMachine then return false end
        if not Hub.carnivalGetMachine() then return false end
        local label = Hub.carnivalGetCooldownLabel()
        if label then
            cooldownStarted = true
            break
        end
        task.wait(0.2)
    end

    if not cooldownStarted then
        -- Container never appeared — might already be on cooldown from before,
        -- or machine has no cooldown UI yet. Either way safe to proceed.
        return true
    end

    -- Phase 2: Wait for cooldown to finish (label says "GO!" or container hidden)
    while Hub.carnivalAutoMachine do
        if not Hub.carnivalGetMachine() then return false end
        local label = Hub.carnivalGetCooldownLabel()
        -- If container hidden or label says GO! — cooldown done
        if not label then
            return true
        end
        if label.Text == "GO!" then
            return true
        end
        local s = label.Text:match("(%d+)s")
        if s then
        end
        task.wait(1)
    end
    return false
end

-- ============================================================================
-- MINIGAME WATCHER — must start BEFORE combine since combine blocks the thread
-- ============================================================================
function Hub.carnivalStartMinigameWatcher()
    local pg = LocalPlayer:WaitForChild("PlayerGui")
    local soloGui = pg:WaitForChild("SoloPopcornBurstGui", 10)

    local circleHolder = soloGui:WaitForChild("CircleHolder", 10)


    local done = { finished = false }
    local watcherConns = {}

    local function handleRing(button)
        if not button:IsA("TextButton") then return end

        -- Find the shrinking frame (largest Frame child, starts at ~0.65 scale)
        local shrinkFrame = nil
        local maxScale = -1
        for _, child in pairs(button:GetChildren()) do
            if child:IsA("Frame") then
                local sx = child.Size.X.Scale
                if sx > maxScale then maxScale = sx; shrinkFrame = child end
            end
        end

        if not shrinkFrame then
            Hub.carnivalPop()
            return
        end


        -- Fire at 0.37 on Heartbeat.
        -- Firing at 0.42 consistently gave Great (just outside server perfect window).
        -- Moving deeper into the zone to 0.37 to hit server Perfect window.
        -- Perfect zone from decompiled v_u_32: 0.30 <= Size.X.Scale <= 0.47
        local FIRE_AT = 0.37

        local fired = false
        local conn
        conn = RunService.Heartbeat:Connect(function()
            if fired then conn:Disconnect(); return end
            if not shrinkFrame or not shrinkFrame.Parent then
                if not fired then
                    fired = true
                    conn:Disconnect()
                    Hub.carnivalPop()
                end
                return
            end
            local scale = shrinkFrame.Size.X.Scale
            if scale <= FIRE_AT then
                fired = true
                conn:Disconnect()
                Hub.carnivalPop()
            elseif scale < 0.05 and not fired then
                fired = true
                conn:Disconnect()
                Hub.carnivalPop()
            end
        end)
        table.insert(watcherConns, conn)

        local t0 = os.clock()
        while button and button.Parent and os.clock() - t0 < 10 do task.wait(0.05) end
        pcall(function() conn:Disconnect() end)
    end

    for _, child in pairs(circleHolder:GetChildren()) do task.spawn(handleRing, child) end

    local addedConn = circleHolder.ChildAdded:Connect(function(child)
        task.spawn(handleRing, child)
    end)
    table.insert(watcherConns, addedConn)

    task.spawn(function()
        -- Wait for GUI to become enabled (server starts minigame), up to 30s
        local t0 = os.clock()
        while not soloGui.Enabled and os.clock() - t0 < 30 do task.wait(0.05) end

        if soloGui.Enabled then
            local t1 = os.clock()
            while soloGui.Enabled and os.clock() - t1 < 60 do task.wait(0.1) end
        else
        end

        for _, c in ipairs(watcherConns) do pcall(function() c:Disconnect() end) end
        done.finished = true
    end)

    return done
end

function Hub.carnivalDoDeposit()
    if Hub.carnivalIsDepositing then return false end
    Hub.carnivalIsDepositing = true
    local machine = Hub.carnivalGetMachine()
    if not machine then Hub.carnivalIsDepositing = false; return false end

    Hub.carnivalTweenTo()
    task.wait(0.3)

    local used = {}
    local anySlotSet = false
    for i, slot in ipairs({ Hub.carnivalSlot1, Hub.carnivalSlot2, Hub.carnivalSlot3 }) do
        if slot ~= "None" then
            anySlotSet = true
            local scaleF = (i == 3) and Hub.carnivalSlot3Scale    or {"Any"}
            local mutF   = (i == 3) and Hub.carnivalSlot3Mutations or {"Any"}
            local tool   = Hub.carnivalFindByRarity(slot, used, scaleF, mutF)
            if tool then
                table.insert(used, tool)
                Hub.carnivalEquip(tool)
                task.wait(0.25)
                Hub.carnivalDeposit(machine)
                task.wait(0.25)
                Hub.carnivalUnequip()
                task.wait(0.1)
            else
                Hub.carnivalIsDepositing = false
                WindUI:Notify({
                    Title   = "Prize Machine",
                    Content = "Missing " .. slot .. " brainrot for Slot " .. i .. "!",
                    Duration = 5,
                    Icon    = "alert-circle"
                })
                return false
            end
        end
    end

    Hub.carnivalIsDepositing = false
    return anySlotSet
end

