end

function Hub.startEventPollLoop()
    if Hub.webhookEventPollThread then
        task.cancel(Hub.webhookEventPollThread)
        Hub.webhookEventPollThread = nil
    end
    Hub.webhookEventNotified = {}
    Hub.webhookEventPollThread = task.spawn(function()
        while Hub.webhookEnabled_Events do
            pcall(function()
                local slots = {
                    {
                        t     = tonumber(Workspace:GetAttribute("TimeUntilEvent")),
                        etype = tostring(Workspace:GetAttribute("NextEventType") or "")
                    },
                    {
                        t     = tonumber(Workspace:GetAttribute("TimeUntilEvent2")),
                        etype = tostring(Workspace:GetAttribute("NextEventType2") or "")
                    },
                }
                for _, entry in ipairs(slots) do
                    local t, etype = entry.t, entry.etype
                    if t and t > 0 and t <= Hub.webhookEventThreshold and etype ~= "" then
                        if Hub.shouldNotifyEvent(etype) and not Hub.webhookEventNotified[etype] then
                            Hub.webhookEventNotified[etype] = true
                            Hub.send(
                                "Event Starting Soon - " .. etype,
                                "**Event:** " .. etype .. "\n**Starts In:** " .. math.floor(t) .. "s",
                                0xFFA500, Hub.webhookEnabled_Events
                            )
                        end
                    elseif t and t > Hub.webhookEventThreshold then
                        Hub.webhookEventNotified[etype] = false
                    end
                end
            end)
            task.wait(5)
        end
    end)
end

function Hub.stopEventPollLoop()
    if Hub.webhookEventPollThread then
        task.cancel(Hub.webhookEventPollThread)
        Hub.webhookEventPollThread = nil
    end
    Hub.webhookEventNotified = {}
end

function Hub.onLuckyBlockAdded(lb)
    if not Hub.webhookEnabled_LuckyBlock then return end

    if Hub.webhookCooldowns[lb] then return end
    Hub.webhookCooldowns[lb] = true

    pcall(function()
        lb.AncestryChanged:Connect(function()
            if not lb.Parent then Hub.webhookCooldowns[lb] = nil end
        end)
    end)

    task.wait(0.15)
    if not lb or not lb.Parent then return end

    local lbType   = Hub.getLuckyBlockType(lb)
    local rarity   = tostring(Hub.getAttr(lb, "Rarity") or Hub.getAttr(lb, "Class") or Hub.getAttr(lb, "RarityName") or "Unknown")
    local mutation = tostring(Hub.getAttr(lb, "Mutation") or "None")

    if not Hub.shouldNotifyLuckyType(lbType) then return end

    local color = Hub.RARITY_COLORS[lbType] or Hub.RARITY_COLORS[rarity] or 0xFFD700

    Hub.send(
        "Lucky Block Spawned - " .. lbType,
        "**Type:** " .. lbType .. "\n**Rarity:** " .. rarity .. "\n**Mutation:** " .. mutation,
        color, Hub.webhookEnabled_LuckyBlock
    )
end

function Hub.startLuckyBlockListeners()
    for _, conn in pairs(Hub.webhookLuckyBlockListeners) do pcall(function() conn:Disconnect() end) end
    Hub.webhookLuckyBlockListeners = {}
    for _, conn in pairs(Hub.webhookLuckyFolderConns) do pcall(function() conn:Disconnect() end) end
    Hub.webhookLuckyFolderConns = {}

    local folderNames = {
        "ActiveLuckyBlocks", "LuckyBlocks", "SpawnedLuckyBlocks",
        "ActiveLuckBlocks",  "LuckBlocks",  "SpawnedLuckBlocks"
    }

    local found = false
    for _, fname in ipairs(folderNames) do
        local folder = Workspace:FindFirstChild(fname)
        if folder then
            found = true
            for _, lb in pairs(folder:GetChildren()) do
                task.spawn(function() Hub.onLuckyBlockAdded(lb) end)
            end
            local itemConn = folder.ChildAdded:Connect(function(lb)
                task.spawn(function() Hub.onLuckyBlockAdded(lb) end)
            end)
            table.insert(Hub.webhookLuckyBlockListeners, itemConn)
        end
    end

    if not found then
        warn("[Webhook] Lucky Block folder not found - will retry via ChildAdded on workspace")
        local watchConn
        watchConn = Workspace.ChildAdded:Connect(function(child)
            for _, fname in ipairs(folderNames) do
                if child.Name == fname then
                    watchConn:Disconnect()
                    for _, lb in pairs(child:GetChildren()) do
                        task.spawn(function() Hub.onLuckyBlockAdded(lb) end)
                    end
                    local itemConn = child.ChildAdded:Connect(function(lb)
                        task.spawn(function() Hub.onLuckyBlockAdded(lb) end)
                    end)
                    table.insert(Hub.webhookLuckyBlockListeners, itemConn)
                    break
                end
            end
        end)
        table.insert(Hub.webhookLuckyFolderConns, watchConn)
    end
end

function Hub.stopLuckyBlockListeners()
    for _, conn in pairs(Hub.webhookLuckyBlockListeners) do pcall(function() conn:Disconnect() end) end
    Hub.webhookLuckyBlockListeners = {}
    for _, conn in pairs(Hub.webhookLuckyFolderConns) do pcall(function() conn:Disconnect() end) end
    Hub.webhookLuckyFolderConns = {}
end

function Hub.startInventoryPollLoop()
    if Hub.webhookInventoryPollThread then
        task.cancel(Hub.webhookInventoryPollThread)
        Hub.webhookInventoryPollThread = nil
    end
    Hub.webhookInventoryNotified = false
    Hub.webhookInventoryPollThread = task.spawn(function()
        while Hub.webhookEnabled_Inventory do
            pcall(function()
                local count = Hub.getInventoryCount()
                if count >= Hub.webhookInventoryThreshold then
                    if not Hub.webhookInventoryNotified then
                        Hub.webhookInventoryNotified = true
                        Hub.send(
                            "Inventory Full!",
