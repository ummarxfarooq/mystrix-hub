function Hub.fireMachinePromptOnce()
    pcall(function()
        local machinePos = Hub.getMachinePosition()
        if not machinePos then return end

        -- Move to machine (underground)
        Hub.goUnderground()
        Hub.tweenUnderground(Vector3.new(machinePos.X, Hub.TWEEN_Y, machinePos.Z))

        -- Rise to the machine's Y level
        local hrp = Hub.getHRP()
        if not hrp then return end
        local riseDist = math.abs(machinePos.Y - Hub.TWEEN_Y)
        local riseTime = math.clamp(riseDist / 80, 0.05, 1.5)
        local riseTween = TweenService:Create(hrp, TweenInfo.new(riseTime, Enum.EasingStyle.Linear), {
            CFrame = CFrame.new(machinePos.X, machinePos.Y, machinePos.Z)
        })
        riseTween:Play()
        riseTween.Completed:Wait()

        -- Fire the proximity prompt multiple times to ensure it registers
        local prompt = Hub.getMachinePrompt()
        if prompt and prompt:IsA("ProximityPrompt") then
            for i = 1, 5 do
                if not prompt.Parent then break end
                fireproximityprompt(prompt)
                task.wait(0.1)
            end
        end

        -- Go back underground and return to original position (optional)
        Hub.snapBackUnderground(machinePos.X, machinePos.Z)
        Hub.enableAntiRagdoll()
    end)
end

