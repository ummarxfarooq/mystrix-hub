function Hub.lsGetStormXZ()
    local rain = Workspace:FindFirstChild("RainVFX", true)
    if not rain then return nil, nil end
    local sumX, sumZ, count = 0, 0, 0
    for _, p in pairs(rain:GetDescendants()) do
        if p:IsA("BasePart") then
            sumX = sumX + p.Position.X
            sumZ = sumZ + p.Position.Z
            count = count + 1
        end
    end
    if count > 0 then return sumX / count, sumZ / count end
    local ok, cf = pcall(function() return rain:GetBoundingBox() end)
    if ok and cf then return cf.Position.X, cf.Position.Z end
    return nil, nil
end

function Hub.lsWaveNearby()
    local char = LocalPlayer.Character
    if not char then return false end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if not hrp then return false end
    local tsunamis = Workspace:FindFirstChild("ActiveTsunamis")
    if not tsunamis then return false end
    local playerX = hrp.Position.X
    local playerZ = hrp.Position.Z
    for _, wave in pairs(tsunamis:GetChildren()) do
        local function checkPart(part)
            if not part:IsA("BasePart") then return false end
            local aheadDist = part.Position.X - playerX
            local zDist     = math.abs(part.Position.Z - playerZ)
            if aheadDist > 0 and aheadDist < Hub.LS_WAVE_DIST and zDist < 200 then
                return true
            end
            return false
        end
        if wave:IsA("BasePart") then
            if checkPart(wave) then return true end
        else
            for _, part in pairs(wave:GetDescendants()) do
                if checkPart(part) then return true end
            end
        end
    end
    return false
end

function Hub.lsTweenTo(targetX, targetZ, targetY)
