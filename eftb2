Hub.UI.CarnivalAutoMachineToggle = Hub.CarnivalMachineSection:Toggle({
    Title    = "Auto Prize Machine",
    Flag     = "CarnivalAutoMachine",
    Value    = false,
    Callback = function(v)
        Hub.carnivalAutoMachine = v
        if Hub.carnivalMachineLoop then task.cancel(Hub.carnivalMachineLoop); Hub.carnivalMachineLoop = nil end
        if not v then return end

        if Hub.carnivalSlot1 == "None" and Hub.carnivalSlot2 == "None" and Hub.carnivalSlot3 == "None" then
            Hub.carnivalAutoMachine = false
            WindUI:Notify({ Title = "Prize Machine", Content = "Select at least one slot rarity!", Duration = 4, Icon = "alert-circle" })
            return
        end

        Hub.carnivalMachineLoop = task.spawn(function()
            while Hub.carnivalAutoMachine do

                -- 1. Wait for machine to exist
                local machine = Hub.carnivalGetMachine()
                if not machine then
                    task.wait(2)
                    continue
                end

                -- 2. Wait for cooldown to fully finish
                -- carnivalWaitForCooldown handles the race condition where the
                -- CooldownContainer hasn't become visible yet right after a combine
                local ready = Hub.carnivalWaitForCooldown()
                if not ready then task.wait(1); continue end

                -- 3. Confirm machine still exists
                machine = Hub.carnivalGetMachine()
                if not machine then task.wait(2); continue end

                -- 4. Deposit brainrots
                local depositOk = Hub.carnivalDoDeposit()
                if not depositOk then
                    task.wait(3)
                    continue
                end

                -- 5. Confirm machine still here after deposit
                machine = Hub.carnivalGetMachine()
                if not machine then task.wait(2); continue end

                -- 6. Start watcher BEFORE combine (combine blocks thread for whole minigame)
                local watcherDone = Hub.carnivalStartMinigameWatcher()
                if not watcherDone then task.wait(2); continue end

                task.spawn(function()
                    Hub.carnivalCombine(machine)
                end)

                -- 7. Wait for minigame watcher to finish
                local t0 = os.clock()
                while not watcherDone.finished and os.clock() - t0 < 90 do
                    task.wait(0.5)
                end

                -- Hard 10s cooldown that exists after every minigame but has no UI
                task.wait(10)

                -- Loop back to top — carnivalWaitForCooldown will now properly
                -- wait for the CooldownContainer to appear AND then disappear
            end

        end)
    end,
})

