function Hub.openAllChests()
    local chests = CollectionService:GetTagged("StPatricksChest")
    if #chests == 0 then
        for _, obj in pairs(Workspace:GetDescendants()) do
            if obj:IsA("Model") and obj.Name:lower():find("chest") and not obj:GetAttribute("Opened") then
                table.insert(chests, obj)
            end
        end
    end

    for _, chest in ipairs(chests) do
        if not Hub.autoDepositEnabled then break end
        if not chest or not chest.Parent then continue end
        if chest:GetAttribute("Opened") then continue end

        local primary = chest.PrimaryPart
        if not primary then continue end

        local chestPos = chest:GetPivot().Position

        -- Move to chest
        Hub.goUnderground()
        Hub.tweenUnderground(Vector3.new(chestPos.X, Hub.TWEEN_Y, chestPos.Z))
        if not Hub.isAlive() then
            while Hub.autoDepositEnabled and not Hub.isAlive() do task.wait(0.3) end
            if not Hub.autoDepositEnabled then break end
            task.wait(0.5)
            Hub.goUnderground()
        end

        -- Rise to chest
        Hub.riseToY(chestPos.Y, chestPos.X, chestPos.Z)

        -- Open chest
        local prompt = primary:FindFirstChildWhichIsA("ProximityPrompt", true)
            or chest:FindFirstChildWhichIsA("ProximityPrompt", true)
        if prompt then
            for i = 1, 5 do
                if not prompt.Parent then break end
                fireproximityprompt(prompt)
                task.wait(0.1)
            end
        end

        -- Wait for brainrots to spawn
        task.wait(2.0)

        -- Fire prompts of all debris brainrots (once each)
        local debrisBrainrots = Hub.getDebrisBrainrots()
        for _, brainrot in ipairs(debrisBrainrots) do
            local prompt = brainrot:FindFirstChildWhichIsA("ProximityPrompt", true)
            if prompt then
                fireproximityprompt(prompt)
            end
        end

        -- Wait a tiny moment for the game to register (optional)
        task.wait(0.3)

        -- ALWAYS go to claim position, regardless of whether we gained anything
        Hub.snapBackUnderground(chestPos.X, chestPos.Z)  -- go underground at chest
        Hub.goUnderground()
        Hub.tweenUnderground(Vector3.new(Hub.CLAIM_POS.X, Hub.TWEEN_Y, Hub.CLAIM_POS.Z))
        Hub.riseToY(Hub.CLAIM_POS.Y, Hub.CLAIM_POS.X, Hub.CLAIM_POS.Z)
        task.wait(0.5)  -- simulate claiming
        Hub.snapBackUnderground(Hub.CLAIM_POS.X, Hub.CLAIM_POS.Z)

        task.wait(0.2)  -- small delay before next chest
    end

    Hub.disableAntiRagdoll()
    Hub.unequipAll()
end

function Hub.getTimeUntilStPatricks()
    local t1, t2     = nil, nil
    local type1, type2 = nil, nil
    pcall(function() t1    = tonumber(Workspace:GetAttribute("TimeUntilEvent"))  end)
    pcall(function() type1 = Workspace:GetAttribute("NextEventType")             end)
    pcall(function() t2    = tonumber(Workspace:GetAttribute("TimeUntilEvent2")) end)
    pcall(function() type2 = Workspace:GetAttribute("NextEventType2")            end)
    local best = nil
    if t1 and t1 > 0 and tostring(type1) == "StPatricks" then best = t1 end
    if t2 and t2 > 0 and tostring(type2) == "StPatricks" then
        if not best or t2 < best then best = t2 end
    end
    return best
end

Hub.preEventActive = false

function Hub.runPreEventCollect()
    local alreadyCollected = {}
    local startTime = os.time()
    while Hub.autoDepositEnabled and Hub.preEventActive do
        if os.time() - startTime > 55 then break end
        if Hub.countBrainrotsCarried() >= Hub.depositCarryLimit then break end
        if not Hub.isAlive() then
            while Hub.autoDepositEnabled and not Hub.isAlive() do task.wait(0.3) end
            if not Hub.autoDepositEnabled then break end
            task.wait(0.5)
            Hub.goUnderground()
            alreadyCollected = {}
            continue
        end
        local timeLeft = Hub.getTimeUntilStPatricks()
        if not timeLeft or timeLeft <= 0 then break end
        local brainrot = Hub.findBestBrainrot(alreadyCollected)
        if not brainrot then task.wait(0.5); continue end
        Hub.collectBrainrot(brainrot)
        alreadyCollected[brainrot] = true
        task.wait(0.05)
    end
end

function Hub.waitForMachineAndDeposit()
    if Hub.countBrainrotsCarried() == 0 then return end
    local waitStart = os.time()
    local hrp = Hub.getHRP()
    if hrp then
        Hub.enableAntiRagdoll()
        local waitCFrame = CFrame.new(Hub.PRE_EVENT_WAIT_POS.X, Hub.TWEEN_Y, Hub.PRE_EVENT_WAIT_POS.Z)
        local dist = (Vector3.new(hrp.Position.X, 0, hrp.Position.Z) - Vector3.new(Hub.PRE_EVENT_WAIT_POS.X, 0, Hub.PRE_EVENT_WAIT_POS.Z)).Magnitude
        if dist > 1 then
            local tweenTime = math.clamp(dist / Hub.depositTweenSpeed, 0.1, 5)
            local tween = TweenService:Create(hrp, TweenInfo.new(tweenTime, Enum.EasingStyle.Linear, Enum.EasingDirection.Out), {CFrame = waitCFrame})
            tween:Play()
            tween.Completed:Wait()
        else
            hrp.CFrame = waitCFrame
        end
    end
    while Hub.autoDepositEnabled and os.time() - waitStart < 60 do
        if Hub.isEventActive() then
            Hub.hookConfirm()
            Hub.depositAtMachine()
            return
        end
        if not Hub.isAlive() then
            while Hub.autoDepositEnabled and not Hub.isAlive() do task.wait(0.3) end
            if not Hub.autoDepositEnabled then break end
            task.wait(0.5)
            Hub.goUnderground()
            local newHrp = Hub.getHRP()
            if newHrp then
                newHrp.CFrame = CFrame.new(Hub.PRE_EVENT_WAIT_POS.X, Hub.TWEEN_Y, Hub.PRE_EVENT_WAIT_POS.Z)
            end
        else
            Hub.enableAntiRagdoll()
            local curHrp = Hub.getHRP()
            if curHrp then
                local d = (Vector3.new(curHrp.Position.X, 0, curHrp.Position.Z) - Vector3.new(Hub.PRE_EVENT_WAIT_POS.X, 0, Hub.PRE_EVENT_WAIT_POS.Z)).Magnitude
                if d > 3 then
                    curHrp.CFrame = CFrame.new(Hub.PRE_EVENT_WAIT_POS.X, Hub.TWEEN_Y, Hub.PRE_EVENT_WAIT_POS.Z)
                end
            end
        end
        task.wait(0.5)
    end
end

function Hub.startDepositLoop()
    if Hub.depositLoop then task.cancel(Hub.depositLoop) end
    Hub.depositLoop = task.spawn(function()
        while Hub.autoDepositEnabled do

            local timeUntil = Hub.getTimeUntilStPatricks()
            if timeUntil and timeUntil > 0 and timeUntil <= 60 then
                Hub.preEventActive = true
                Hub.runPreEventCollect()
                Hub.preEventActive = false
                Hub.waitForMachineAndDeposit()
            end

            while Hub.autoDepositEnabled and not Hub.isEventActive() do
                local t = Hub.getTimeUntilStPatricks()
                if t and t > 0 and t <= 60 and not Hub.preEventActive then
                    Hub.preEventActive = true
                    Hub.runPreEventCollect()
                    Hub.preEventActive = false
                    Hub.waitForMachineAndDeposit()
                end
                Hub.unequipAll()
                task.wait(2)
            end
            if not Hub.autoDepositEnabled then break end

            Hub.hookConfirm()

            while Hub.autoDepositEnabled and Hub.isEventActive() do
                if not Hub.isAlive() then task.wait(1); continue end

                if Hub.isRainbowComplete() then
                    Hub.disableAntiRagdoll()
                    task.wait(1)
                    -- EXTRA MACHINE TRIGGER BEFORE CHESTS
                    Hub.fireMachinePromptOnce()
                    task.wait(0.3)
                    Hub.openAllChests()
                    break
                end

                Hub.unequipAll()
                local carrying = Hub.countBrainrotsCarried()

                if Hub.autoDepositBest then
                    if carrying >= Hub.depositCarryLimit then
                        Hub.depositAtMachine()
                    else
                        local alreadyCollected = {}
                        while Hub.autoDepositEnabled and Hub.countBrainrotsCarried() < Hub.depositCarryLimit do
                            if not Hub.isEventActive() then break end
                            if not Hub.isAlive() then break end
                            if Hub.isRainbowComplete() then break end
                            local brainrot = Hub.findBestBrainrot(alreadyCollected)
                            if not brainrot then task.wait(0.3); break end
                            Hub.collectBrainrot(brainrot)
                            alreadyCollected[brainrot] = true
                        end
                        if Hub.countBrainrotsCarried() > 0 and not Hub.isRainbowComplete() then Hub.depositAtMachine() end
                    end
                else
                    if Hub.isRainbowComplete() then
                        Hub.disableAntiRagdoll()
                        task.wait(1)
                        -- EXTRA MACHINE TRIGGER BEFORE CHESTS
                        Hub.fireMachinePromptOnce()
                        task.wait(0.3)
                        Hub.openAllChests()
                        break
                    end

                    if carrying > 0 then
                        Hub.depositAtMachine()
                    else
                        local brainrot = Hub.findBestBrainrot(nil)
                        if brainrot then
                            if Hub.isRainbowComplete() then
                                Hub.disableAntiRagdoll()
                                task.wait(1)
                                -- EXTRA MACHINE TRIGGER BEFORE CHESTS
                                Hub.fireMachinePromptOnce()
                                task.wait(0.3)
                                Hub.openAllChests()
                                break
                            end
                            local ok = Hub.collectBrainrot(brainrot)
                            if ok then
                                if Hub.isRainbowComplete() then
                                    Hub.disableAntiRagdoll()
                                    task.wait(1)
                                    -- EXTRA MACHINE TRIGGER BEFORE CHESTS
                                    Hub.fireMachinePromptOnce()
                                    task.wait(0.3)
                                    Hub.openAllChests()
                                    break
                                end
                                Hub.depositAtMachine()
                            else
                                task.wait(0.05)
                            end
                        else
                            task.wait(0.3)
                        end
                    end
                end

                task.wait(0.05)
            end

            Hub.disableAntiRagdoll()
            task.wait(3)
        end
        Hub.disableAntiRagdoll()
        Hub.unequipAll()
    end)
end

function Hub.stopDeposit()
    Hub.autoDepositEnabled   = false
    if Hub.depositLoop then task.cancel(Hub.depositLoop); Hub.depositLoop = nil end
    Hub.stopTween()
    Hub.depositIsCollecting  = false
    Hub.depositIsDepositing  = false
    Hub.depositIsTweening    = false
    Hub.disableAntiRagdoll()
    Hub.unequipAll()
end

