Hub.mgAutoPopEnabled = false
Hub.mgPopLoop        = nil

function Hub.mgFirePop()
    pcall(function()
        local remotes = require(ReplicatedStorage:WaitForChild("Shared"):WaitForChild("Remotes"))
        remotes.MinigameGameAction:FireServer("AttemptPop", Workspace:GetServerTimeNow())
    end)
end

function Hub.mgStartLoop()
    if Hub.mgPopLoop then task.cancel(Hub.mgPopLoop); Hub.mgPopLoop = nil end

    Hub.mgPopLoop = task.spawn(function()
        local pg = LocalPlayer:WaitForChild("PlayerGui")
        local minigameGui = pg:WaitForChild("MinigameGui", 10)
        if not minigameGui then return end
        local games = minigameGui:WaitForChild("Games", 10)
        if not games then return end
        local burstGui = games:WaitForChild("PopcornBurstGui", 10)
        if not burstGui then return end
        local holder = burstGui:WaitForChild("Holder", 10)
        if not holder then return end

        local activeConns = {}

        local function handleChild(child)
            if not Hub.mgAutoPopEnabled then return end

            if child:IsA("TextButton") then
                local shrinkFrame = nil
                local maxScale = -1
                for _, c in pairs(child:GetChildren()) do
                    if c:IsA("Frame") then
                        local sx = c.Size.X.Scale
                        if sx > maxScale then maxScale = sx; shrinkFrame = c end
                    end
                end
                if not shrinkFrame then Hub.mgFirePop(); return end

                local initScale = shrinkFrame.Size.X.Scale
                if initScale < 0.05 then return end
                if initScale <= 0.45 then
                    Hub.mgFirePop()
                    return
                end

                local fired = false
                local conn
                conn = RunService.Heartbeat:Connect(function()
                    if fired then conn:Disconnect(); activeConns[conn] = nil; return end
                    if not shrinkFrame or not shrinkFrame.Parent or not child.Parent then
                        if not fired then
                            fired = true; conn:Disconnect(); activeConns[conn] = nil
                            Hub.mgFirePop()
                        end
                        return
                    end
                    local scale = shrinkFrame.Size.X.Scale
                    if scale <= 0.45 then
                        fired = true; conn:Disconnect(); activeConns[conn] = nil
                        Hub.mgFirePop()
                    end
                end)
                activeConns[conn] = true

            elseif child:IsA("Frame") then
                local sx = child.Size.X.Scale
                if sx >= 0.09 and sx <= 0.13 then
                    Hub.mgFirePop()
                end
            end
        end

        for _, c in pairs(holder:GetChildren()) do handleChild(c) end

        local addedConn = holder.ChildAdded:Connect(function(child)
            handleChild(child)
        end)

        while Hub.mgAutoPopEnabled do task.wait(0.5) end

        pcall(function() addedConn:Disconnect() end)
        for c in pairs(activeConns) do pcall(function() c:Disconnect() end) end
        Hub.mgPopLoop = nil
    end)
end

function Hub.mgStopLoop()
    Hub.mgAutoPopEnabled = false
    if Hub.mgPopLoop then
        task.cancel(Hub.mgPopLoop)
        Hub.mgPopLoop = nil
    end
end

