function Hub.arWaitForRespawn(info)
    while Hub.arIsAlive() do task.wait(0.1) end
    while not Hub.arIsAlive() do task.wait(0.1) end
    task.wait(0.5)
    local cx = Hub.arGetCloudXZ()
    Hub.arApproachCloud(cx)
    if info then
        task.wait(0.2)
        local tool = Hub.arFindToolForInfo(info)
        if tool then Hub.arEquipTool(tool) end
    end
end

