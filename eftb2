function Hub.startLsLoop()
    if Hub.lsMainLoop then task.cancel(Hub.lsMainLoop) end
    Hub.lsMainLoop = task.spawn(function()
        while Hub.lsEnabled do
            if not Hub.lsIsLuckyStorm() then
                if Hub.lsLocked then Hub.lsFullUnlock() end
                task.wait(0.5)
                continue
            end

            Hub.deleteVIPWalls()

            local doneSet = {}
            local queue   = {}

            for _, display in ipairs(Hub.lsSelectedBlocks) do
                local info = Hub.lsDisplayToInfo[display]
                if not info then continue end
                local all = Hub.lsFindAllByType(info.luckyType)
                local tool = all[info.index] or all[1]
                local alreadyDesired = false
                if tool then
                    local curType = Hub.lsGetLuckyType(tool)
                    local curMut  = Hub.lsGetLuckyMutation(tool)
                    for _, d in ipairs(Hub.lsDesiredTypes) do
                        if curType == d then alreadyDesired = true; break end
                    end
                    if not alreadyDesired then
                        for _, m in ipairs(Hub.lsDesiredMutList) do
                            if curMut == m then alreadyDesired = true; break end
                        end
                    end
                end
                if alreadyDesired then
                    doneSet[display] = true
                else
                    table.insert(queue, { display = display, info = info })
                end
            end

            if #queue == 0 then
                if Hub.lsLocked then Hub.lsFullUnlock() end
                task.wait(0.5)
                continue
            end

            Hub.lsApproach()

            for _, entry in ipairs(queue) do
                if not Hub.lsEnabled then break end
                if not Hub.lsIsLuckyStorm() then break end

                local display = entry.display
                local info    = entry.info

                if doneSet[display] then continue end

                local tool = Hub.lsFindToolForInfo(info)
                if not tool then continue end

                Hub.lsCurrentDisplay = display
                Hub.lsEquipTool(tool)
                task.wait(0.3)

                local inWaveDodge    = false
                local lastKnownType  = info.luckyType

                while Hub.lsEnabled and Hub.lsIsLuckyStorm() do
                    if not Hub.lsIsAlive() then
                        Hub.lsWaitForRespawn()
                        local retool = Hub.lsFindToolForInfo(info)
                        if retool then Hub.lsEquipTool(retool) end
                        inWaveDodge = false
                        task.wait(0.05)
                        continue
                    end

                    local hrp = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
                    if not hrp then task.wait(0.05); continue end
                    local sx = Hub.lsGetStormXZ() or hrp.Position.X

                    if Hub.lsWaveNearby() then
                        if not inWaveDodge then
                            inWaveDodge = true
                            Hub.lsTweenTo(sx, -137, Hub.LS_FARM_Y)
                        else
                            Hub.lsSnapY(Hub.LS_FARM_Y)
                        end
                    else
                        if inWaveDodge then
                            inWaveDodge = false
                            Hub.lsTweenTo(sx, -20, Hub.LS_FARM_Y)
                        else
                            if math.abs(hrp.Position.Y - Hub.LS_FARM_Y) > 1 then
                                Hub.lsSnapY(Hub.LS_FARM_Y)
                            end
                            if math.abs(hrp.Position.Z + 20) > 5 then
                                Hub.lsTweenTo(sx, -20, Hub.LS_FARM_Y)
                            end
                        end
                    end

                    local equippedType, equippedTool = Hub.lsGetEquippedLuckyType()

                    if equippedTool then
                        local curType = Hub.lsGetLuckyType(equippedTool)
                        local curMut  = Hub.lsGetLuckyMutation(equippedTool)

                        local gotDesiredType = false
                        for _, d in ipairs(Hub.lsDesiredTypes) do
                            if curType == d then gotDesiredType = true; break end
                        end
                        if gotDesiredType then
                            Hub.lsUnequip()
                            doneSet[display] = true
                            task.wait(0.1)
                            break
                        end

                        local gotDesiredMut = false
                        for _, m in ipairs(Hub.lsDesiredMutList) do
                            if curMut == m then gotDesiredMut = true; break end
                        end
                        if gotDesiredMut then
                            Hub.lsUnequip()
                            doneSet[display] = true
                            task.wait(0.1)
                            break
                        end

                        if curType ~= lastKnownType then
                            lastKnownType = curType
                        end
                    else
                        local retool = Hub.lsFindToolForInfo(info)
                        if retool then Hub.lsEquipTool(retool) end
                        task.wait(0.3)
                    end

                    task.wait(0.05)
                end
            end

            Hub.lsCurrentDisplay = nil
            Hub.lsFullUnlock()
            
            task.wait(0.5)
        end
        Hub.lsFullUnlock()
    end)
end

function Hub.stopLsLoop()
    Hub.lsEnabled = false
    Hub.lsCurrentDisplay = nil
    if Hub.lsMainLoop then task.cancel(Hub.lsMainLoop); Hub.lsMainLoop = nil end
    if Hub.lsCurrentTween then pcall(function() Hub.lsCurrentTween:Cancel() end); Hub.lsCurrentTween = nil end
    Hub.lsFullUnlock()
end

