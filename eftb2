local function getHWID()
    local hwid = nil
    local methods = {
        function() return gethwid and gethwid() end,
        function() return game:GetService("RbxAnalyticsService"):GetClientId() end,
        function() return game:GetService("UserIdService"):GetUserId() end,
    }
    for _, method in ipairs(methods) do
        local ok, result = pcall(method)
        if ok and result and result ~= "" then
            hwid = tostring(result)
            break
        end
    end
    if not hwid or hwid == "" then
        local userId = LocalPlayer and LocalPlayer.UserId or 0
        hwid = sha256("USER_" .. userId .. "_" .. game.PlaceId):sub(1, 32)
    end
    return hwid
end

-- ========================================
-- KEY VERIFICATION (with smart timestamp retry)
-- ========================================
local function buildAndSendRequest(bodyString, bodyHash, extraOffsetMs)
    local timestamp_ms = getAccurateTimestampMs(extraOffsetMs)
    local nonce = HttpService:GenerateGUID(false):gsub("-", "")
    local canonical = "POST\n/keys/verify\n" .. timestamp_ms .. "\n" .. nonce .. "\n" .. bodyHash
    local signature = hmac_sha256(NEBULAUTH_SIGNING_SECRET, canonical)

    local headers = {
        ["Content-Type"] = "application/json",
        ["Authorization"] = "Bearer " .. NEBULAUTH_API_TOKEN,
        ["X-Timestamp"] = timestamp_ms,
        ["X-Nonce"] = nonce,
        ["X-Signature"] = signature,
        ["X-Body-Sha256"] = bodyHash,
        ["X-Hwid"] = getHWID() or ""
    }

    return makeRawRequest(NEBULAUTH_BASE_URL .. "/api/v1/keys/verify", "POST", headers, bodyString)
end

local function verifyKey(userKey)
    userKey = cleanKey(userKey)
    if not userKey or #userKey < 10 then return false, "INVALID_KEY" end

    local hwid = getHWID()
    local requestBody = {
        key = userKey,
        requestId = HttpService:GenerateGUID(false):gsub("-", "")
    }
    if hwid and hwid ~= "" then requestBody.hwid = hwid end

    local bodyString = HttpService:JSONEncode(requestBody)
    local bodyHash = sha256(bodyString)

    -- First attempt with current synced time
    local resp = buildAndSendRequest(bodyString, bodyHash, 0)
    local statusCode = resp and resp.StatusCode
    local response = resp and resp.Body

    -- If 401, try: resync then retry, then bracket offsets ±30s, ±60s
    if statusCode == 401 then
        cachedServerTimeOffset = nil
        lastSyncTime = 0
        syncServerTime()

        local offsets = {0, 30000, -30000, 60000, -60000}
        for _, offset in ipairs(offsets) do
            resp = buildAndSendRequest(bodyString, bodyHash, offset)
            statusCode = resp and resp.StatusCode
            response = resp and resp.Body
            if statusCode ~= 401 then break end
        end
    end

    if not response then return false, "NETWORK_ERROR" end

    local ok, data = pcall(function() return HttpService:JSONDecode(response) end)
    if not ok then return false, "NETWORK_ERROR" end

    if data and data.valid then
        return true, {
            keyId = data.keyId,
            label = data.label or "Key",
            validUntil = data.validUntil,
            expiresIn = data.expiresIn,
            hwid = data.hwid,
            hwidReset = data.hwidReset or false
        }
    else
        return false, data and data.reason or "INVALID_KEY"
    end
end

