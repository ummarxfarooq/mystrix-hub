function Hub.arIsAcidRain()
    local debris = Workspace:FindFirstChild("Debris")
    if not debris then return false end
    return debris:FindFirstChild("AcidRainClouds") ~= nil
end

function Hub.arGetCloudXZ()
    local debris = Workspace:FindFirstChild("Debris")
    if not debris then return nil, nil end
    local clouds = debris:FindFirstChild("AcidRainClouds")
    if not clouds then return nil, nil end
    local sumX, sumZ, count = 0, 0, 0
    for _, p in pairs(clouds:GetChildren()) do
        if p:IsA("BasePart") then
            sumX = sumX + p.Position.X
            sumZ = sumZ + p.Position.Z
            count = count + 1
        end
    end
    if count > 0 then return sumX / count, sumZ / count end
    return nil, nil
end

function Hub.arWaveNearby()
    local char = LocalPlayer.Character
    if not char then return false end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if not hrp then return false end
    local tsunamis = Workspace:FindFirstChild("ActiveTsunamis")
    if not tsunamis then return false end
    local playerX = hrp.Position.X
    local playerZ = hrp.Position.Z
    for _, wave in pairs(tsunamis:GetChildren()) do
        local function checkPart(part)
            if not part:IsA("BasePart") then return false end
            local aheadDist = part.Position.X - playerX
            local zDist     = math.abs(part.Position.Z - playerZ)
            if aheadDist > 0 and aheadDist < Hub.AR_WAVE_DIST and zDist < 200 then
                return true
            end
            return false
        end
        if wave:IsA("BasePart") then
            if checkPart(wave) then return true end
        else
            for _, part in pairs(wave:GetDescendants()) do
                if checkPart(part) then return true end
            end
        end
    end
    return false
end

function Hub.arTweenTo(targetX, targetZ, targetY)
    local char = LocalPlayer.Character
    if not char then return end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if not hrp then return end
    local y = targetY or Hub.AR_FARM_Y
    if Hub.arCurrentTween then pcall(function() Hub.arCurrentTween:Cancel() end) end
    hrp.CFrame = CFrame.new(hrp.Position.X, y, hrp.Position.Z)
    local dist = (Vector3.new(hrp.Position.X, 0, hrp.Position.Z) - Vector3.new(targetX, 0, targetZ)).Magnitude
    if dist < 2 then
        hrp.CFrame = CFrame.new(targetX, y, targetZ)
        return
    end
    local t = math.clamp(dist / Hub.lsarTweenSpeed, 0.05, 8)
    Hub.arCurrentTween = TweenService:Create(hrp, TweenInfo.new(t, Enum.EasingStyle.Linear), {
        CFrame = CFrame.new(targetX, y, targetZ)
    })
    Hub.arCurrentTween:Play()
    local lockConn
    lockConn = RunService.Heartbeat:Connect(function()
        if not hrp or not hrp.Parent then lockConn:Disconnect(); return end
        hrp.CFrame = CFrame.new(hrp.Position.X, y, hrp.Position.Z)
    end)
    Hub.arCurrentTween.Completed:Wait()
    lockConn:Disconnect()
end

function Hub.arGetToolMutation(tool)
    if not tool then return "None" end
    local mut = tool:GetAttribute("Mutation")
    if mut and mut ~= "" then return tostring(mut) end
    local rendered = tool:FindFirstChild("RenderModel") or tool:FindFirstChild("RenderedBrainrot")
    if rendered then
        local rmut = rendered:GetAttribute("Mutation")
        if rmut then return tostring(rmut) end
    end
    return "None"
end

function Hub.arFindExactTool(brainrotName, requiredMutation)
    local function checkTool(tool)
        if not tool:IsA("Tool") then return false end
        if tool:GetAttribute("BrainrotName") ~= brainrotName then return false end
        if requiredMutation and requiredMutation ~= "" and requiredMutation ~= "None" then
            local mut = Hub.arGetToolMutation(tool)
            return mut == requiredMutation
        end
        return true
    end

    local bp = LocalPlayer:FindFirstChild("Backpack")
    if bp then
        for _, tool in pairs(bp:GetChildren()) do
            if checkTool(tool) then return tool end
        end
    end
    local char = LocalPlayer.Character
    if char then
        for _, tool in pairs(char:GetChildren()) do
            if checkTool(tool) then return tool end
        end
    end
    return nil
end

function Hub.arFindAllByName(brainrotName)
    local results = {}
    local bp = LocalPlayer:FindFirstChild("Backpack")
    if bp then
        for _, tool in pairs(bp:GetChildren()) do
            if tool:IsA("Tool") and tool:GetAttribute("BrainrotName") == brainrotName then
                table.insert(results, tool)
            end
        end
    end
    local char = LocalPlayer.Character
    if char then
        for _, tool in pairs(char:GetChildren()) do
            if tool:IsA("Tool") and tool:GetAttribute("BrainrotName") == brainrotName then
                table.insert(results, tool)
            end
        end
    end
    return results
end

function Hub.arToolInstanceHasDesiredMutation(info)
    local all = Hub.arFindAllByName(info.name)
    for _, tool in ipairs(all) do
        if Hub.arGetToolMutation(tool) == info.mutation then
            local curMut = Hub.arGetToolMutation(tool)
            for _, d in ipairs(Hub.arDesiredMutations) do
                if curMut == d then return true end
            end
        end
    end
    local tool = all[info.index]
    if tool then
        local curMut = Hub.arGetToolMutation(tool)
        for _, d in ipairs(Hub.arDesiredMutations) do
            if curMut == d then return true end
        end
    end
    return false
end

function Hub.arFindToolForInfo(info)
    local all = Hub.arFindAllByName(info.name)
    for _, tool in ipairs(all) do
        local mut = Hub.arGetToolMutation(tool)
        if mut == info.mutation then
            local isDesired = false
            for _, d in ipairs(Hub.arDesiredMutations) do
                if mut == d then isDesired = true; break end
            end
            if not isDesired then return tool end
        end
    end
    return all[info.index]
end

