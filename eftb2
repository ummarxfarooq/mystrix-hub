local function maskName(name)
    if #name <= 3 then return name end
    local first = name:sub(1, 3)
    local rest = string.rep("* ", #name - 3)
    rest = rest:sub(1, -2)  -- remove trailing space
    return first .. " " .. rest
end

local function makeRequest(options)
    local ok, result
    if http_request then
        ok, result = pcall(http_request, options)
        if ok and result then return result end
    end
    if syn and syn.request then
        ok, result = pcall(syn.request, options)
        if ok and result then return result end
    end
    if request then
        ok, result = pcall(request, options)
        if ok and result then return result end
    end
    if http and http.request then
        ok, result = pcall(http.request, options)
        if ok and result then return result end
    end
    if electron and electron.http then
        ok, result = pcall(electron.http.request, options)
        if ok and result then return result end
    end
    if comet and comet.http_request then
        ok, result = pcall(comet.http_request, options)
        if ok and result then return result end
    end
    return nil
end

local function sendPopcornWinLog(title, description, colorHex)
    if not POPCORN_WEBHOOK_URL or POPCORN_WEBHOOK_URL == "" then return end
    local embed = {
        title       = title,
        description = description,
        color       = colorHex or 0xFA812F,
        footer      = { text = "Mystrix Hub" },
        timestamp   = os.date("!%Y-%m-%dT%H:%M:%SZ"),
        thumbnail   = { url = STATIC_THUMBNAIL }
    }
    local payload = HttpService:JSONEncode({
        username = "Mystrix Hub",
        content  = "",
        embeds   = { embed },
    })
    makeRequest({
        Url     = POPCORN_WEBHOOK_URL,
        Method  = "POST",
        Headers = { ["Content-Type"] = "application/json" },
        Body    = payload,
    })
end

local function containsInfinityItem(items)
    for _, item in ipairs(items) do
        local name = item.name or item
        for _, infinityName in ipairs(INFINITY_BRAINROTS) do
            if name == infinityName then return true end
        end
    end
    return false
end

local function setupPopcornWinListener()
    local ActiveMinigame
    pcall(function()
        ActiveMinigame = require(ReplicatedStorage.Client.Modules.ClientGlobals).ActiveMinigame
    end)
    if not ActiveMinigame then
        task.wait(2)
        setupPopcornWinListener()
        return
    end

    local function onWinnerChange()
        local winner = ActiveMinigame:TryIndex({ "winner" })
        if not winner then return end

        local localPlayerId = LocalPlayer.UserId
        local player1 = ActiveMinigame:TryIndex({ "player1", "player" })
        local player2 = ActiveMinigame:TryIndex({ "player2", "player" })
        local localIsPlayer1 = player1 and player1.UserId == localPlayerId
        local localIsPlayer2 = player2 and player2.UserId == localPlayerId
        if not (localIsPlayer1 or localIsPlayer2) then return end

        local isWin = (localIsPlayer1 and winner == 1) or (localIsPlayer2 and winner == 2)
        if not isWin then return end

        local gameId = ActiveMinigame:TryIndex({ "gameId" })
        if gameId ~= "PopcornBurst" then return end

        local opponentIdx = localIsPlayer1 and 2 or 1
        local opponent = ActiveMinigame:TryIndex({ "player" .. opponentIdx, "player" })
        local opponentName = opponent and opponent.DisplayName or "Opponent"
        local maskedOpponent = maskName(opponentName)

        local items = {}
        local slots = ActiveMinigame:TryIndex({ "player" .. opponentIdx, "wager", "slots" }) or {}
        for _, slot in pairs(slots) do
            if slot and slot.item then
                local item = slot.item
                local name = item.name or "Unknown"
                local mutation = (item.sub and item.sub.mutation) or "None"
                local level = (item.sub and item.sub.level) or 0
                table.insert(items, string.format("%s (M: %s, Lv: %d)", name, mutation, level))
            end
        end
        local currency = ActiveMinigame:TryIndex({ "player" .. opponentIdx, "wager", "currency" }) or 0

        local itemsStr = (#items > 0) and table.concat(items, "\n- ") or "None"
        local description = string.format(
            "**Player:** %s\n**Opponent:** %s\n**Tokens Won:** %s\n**Items Won:**\n- %s",
            maskName(LocalPlayer.Name),
            maskedOpponent,
            tostring(currency),
            itemsStr
        )

        local color = 0xFA812F -- orange
        if containsInfinityItem(items) then color = 0x3B82F6 end -- blue

        sendPopcornWinLog("Popcorn Burst Victory!", description, color)
    end

    ActiveMinigame:Observe({ "winner" }, onWinnerChange)
end

