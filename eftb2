function Hub.tnGetItemList()
    local entries = {}
    Hub.tnDisplayToInfo = {}
    local displayCount = {}
    local nameIndex    = {}

    local function addBrainrot(tool, suffix)
        local name = tool:GetAttribute("BrainrotName")
        if not name or name == "" then return end
        local mut         = Hub.tnGetToolMutation(tool)
        local baseDisplay = name .. " [" .. mut .. "]" .. (suffix or "")
        local display     = baseDisplay
        if displayCount[display] then
            displayCount[display] = displayCount[display] + 1
            display = baseDisplay .. " #" .. displayCount[display]
        else
            displayCount[display] = 1
        end
        nameIndex[name] = (nameIndex[name] or 0) + 1
        local idx = nameIndex[name]
        Hub.tnDisplayToInfo[display] = { name = name, mutation = mut, index = idx, isLucky = false }
        table.insert(entries, { display = display, sortKey = Hub.tnGetMutationRank(mut) })
    end

    local function addLuckyBlock(tool, suffix)
        local ltype = tostring(tool:GetAttribute("LuckyBlockType") or "Unknown")
        local baseDisplay = ltype .. " [LuckyBlock]" .. (suffix or "")
        local display     = baseDisplay
        if displayCount[display] then
            displayCount[display] = displayCount[display] + 1
            display = baseDisplay .. " #" .. displayCount[display]
        else
            displayCount[display] = 1
        end
        local lbKey = "LB_" .. ltype
        nameIndex[lbKey] = (nameIndex[lbKey] or 0) + 1
        local idx = nameIndex[lbKey]
        Hub.tnDisplayToInfo[display] = { name = ltype, luckyType = ltype, index = idx, isLucky = true, mutation = "None" }
        table.insert(entries, { display = display, sortKey = 0 })
    end

    local function scanContainer(container, suffix)
        for _, tool in pairs(container:GetChildren()) do
            if not tool:IsA("Tool") then continue end
            if tool:GetAttribute("LuckyBlockTool") == true then
                addLuckyBlock(tool, suffix)
            elseif tool:GetAttribute("BrainrotName") then
                addBrainrot(tool, suffix)
            end
        end
    end

    local bp = LocalPlayer:FindFirstChild("Backpack")
    if bp then scanContainer(bp, "") end
    local char = LocalPlayer.Character
    if char then scanContainer(char, " ★") end

    table.sort(entries, function(a, b) return a.sortKey < b.sortKey end)

    local list = {}
    for _, e in ipairs(entries) do table.insert(list, e.display) end
    if #list == 0 then table.insert(list, "No items found") end
    return list
end

function Hub.startTnLoop()
    if Hub.tnMainLoop then task.cancel(Hub.tnMainLoop) end
    Hub.tnMainLoop = task.spawn(function()
        while Hub.tnEnabled do
            if not Hub.tnTornadoExists() then
                if Hub.tnLocked then Hub.tnFullUnlock() end
                task.wait(0.5)
                continue
            end

            if not Hub.tnSelectedInfo then
                if Hub.tnLocked then Hub.tnFullUnlock() end
                task.wait(0.5)
                continue
            end

            Hub.deleteVIPWalls()

            local info = Hub.tnSelectedInfo
            Hub.tnApproach()

            local tool = Hub.tnFindTool(info)
            if tool then
                Hub.tnEquipTool(tool)
                task.wait(0.3)
            end

            local inWaveDodge = false

            while Hub.tnEnabled and Hub.tnTornadoExists() do
                if not Hub.tnIsAlive() then
                    Hub.tnWaitForRespawn()
                    task.wait(0.2)
                    local retool = Hub.tnFindTool(info)
                    if retool then Hub.tnEquipTool(retool) end
                    inWaveDodge = false
                    task.wait(0.05)
                    continue
                end

                local hrp = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
                if not hrp then task.wait(0.05); continue end
                local tx = Hub.tnGetTornadoX() or hrp.Position.X

                if Hub.tnWaveNearby() then
                    if not inWaveDodge then
                        inWaveDodge = true
                        Hub.tnTweenTo(tx, -137, Hub.TN_FARM_Y)
                    else
                        Hub.tnSnapY(Hub.TN_FARM_Y)
                    end
                else
                    if inWaveDodge then
                        inWaveDodge = false
                        Hub.tnTweenTo(tx, -20, Hub.TN_FARM_Y)
                    else
                        if math.abs(hrp.Position.Y - Hub.TN_FARM_Y) > 1 then
                            Hub.tnSnapY(Hub.TN_FARM_Y)
                        end
                        if math.abs(hrp.Position.Z + 20) > 5 then
                            Hub.tnTweenTo(tx, -20, Hub.TN_FARM_Y)
                        end
                    end
                end

                if not Hub.tnIsItemEquipped(info) then
                    local retool = Hub.tnFindTool(info)
                    if retool then Hub.tnEquipTool(retool) end
                    task.wait(0.3)
                end

                task.wait(0.05)
            end

            Hub.tnFullUnlock()
            task.wait(0.5)
        end
        Hub.tnFullUnlock()
    end)
end

function Hub.stopTnLoop()
    Hub.tnEnabled = false
    if Hub.tnMainLoop then task.cancel(Hub.tnMainLoop); Hub.tnMainLoop = nil end
    if Hub.tnCurrentTween then pcall(function() Hub.tnCurrentTween:Cancel() end); Hub.tnCurrentTween = nil end
    Hub.tnFullUnlock()
end

