    local function extractRarityFromHTML(htmlText)
        if not htmlText then return nil end
        local rarityMatch = htmlText:match('color="#%x+">([^<]+)')
        if rarityMatch then
            local cleanRarity = rarityMatch:gsub(" Brainrot.*$", "")
            for _, rarity in ipairs(RARITY_LIST) do
                if cleanRarity == rarity then return rarity end
            end
        end
        return nil
    end

