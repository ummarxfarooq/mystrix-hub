local function deleteWorkspaceUnderscore()
    pcall(function()
        local underscoreFolder = workspace:FindFirstChild("___")
        if underscoreFolder then
            underscoreFolder:Destroy()
        end
        for _, child in pairs(workspace:GetChildren()) do
            if child.Name:match("^_+$") or child.Name == "___" then
                child:Destroy()
            end
        end
    end)
end
