local function getBrainrotRarity(name)
    return BrainrotToRarity[name] or "Common"
end

local PICKUP_HOLD_DURATION  = 3.0
local ARRIVAL_THRESHOLD     = 2.0
local MOVE_TIMEOUT          = 25

local arenaEnabled     = false
local arenaLoop        = nil
local arenaTweenSpeed  = 500
local flyHeight        = 50
local instantTeleport  = false
local selectedRarities = {"Any"}

local bodyVelocity    = nil
local bodyGyro        = nil
local originalGravity = nil

local cachedBasePart    = nil
local cachedBaseRefresh = 0

local function getCharacter() return LocalPlayer.Character end
local function getHRP()
    local c = getCharacter(); return c and c:FindFirstChild("HumanoidRootPart")
end
local function getHumanoid()
    local c = getCharacter(); return c and c:FindFirstChildOfClass("Humanoid")
end
local function isAlive()
    local c = getCharacter(); if not c then return false end
    local h = c:FindFirstChildOfClass("Humanoid")
    return h and h.Health > 0
end
local function getPartOf(obj)
    if not obj or not obj.Parent then return nil end
    if obj:IsA("BasePart") then return obj end
    if obj.PrimaryPart then return obj.PrimaryPart end
    return obj:FindFirstChildWhichIsA("BasePart", true)
end

local function getArenaBrainrotsFolder()
    return workspace:FindFirstChild("ArenaBrainrots")
end

local function getAvailableBrainrots()
    local folder = getArenaBrainrotsFolder()
    if not folder then return {} end
    local found = {}
    for _, obj in ipairs(folder:GetChildren()) do
        if obj:IsA("Model") and getPartOf(obj) then
            table.insert(found, obj)
        end
    end
    return found
end

local function getBestBrainrot(hrpPos)
    local anySelected = table.find(selectedRarities, "Any") ~= nil
    local list = getAvailableBrainrots()
    if #list == 0 then return nil end

    local allowed = {}
    for _, obj in ipairs(list) do
        local name   = obj:GetAttribute("BrainrotName")
        local rarity = name and getBrainrotRarity(name) or "Common"
        if anySelected then
            table.insert(allowed, {obj = obj, rarity = rarity})
        else
            for _, ar in ipairs(selectedRarities) do
                if rarity == ar then
                    table.insert(allowed, {obj = obj, rarity = rarity})
                    break
                end
            end
        end
    end
    if #allowed == 0 then return nil end

    local bestIdx = math.huge
    local bestRarity = nil
    for _, e in ipairs(allowed) do
        for idx, r in ipairs(RarityOrder) do
            if e.rarity == r and idx < bestIdx then
                bestIdx    = idx
                bestRarity = r
                break
            end
        end
    end
    if not bestRarity then return nil end

    local best, bestDist = nil, math.huge
    for _, e in ipairs(allowed) do
        if e.rarity == bestRarity then
            local p = getPartOf(e.obj)
            if p then
                local d = (p.Position - hrpPos).Magnitude
                if d < bestDist then bestDist = d; best = e.obj end
            end
        end
    end
    return best
end

local function brainrotStillAvailable(obj)
    if not obj or not obj.Parent then return false end
    local folder = getArenaBrainrotsFolder()
    if not folder then return false end
    return obj.Parent == folder
end

local function enablePhysics()
    local hrp = getHRP()
    local hum = getHumanoid()
    if not hrp or not hum then return end
    pcall(function()
        if bodyVelocity and bodyVelocity.Parent then bodyVelocity:Destroy() end
        if bodyGyro     and bodyGyro.Parent     then bodyGyro:Destroy()     end

        hum.PlatformStand = true
        hum.AutoRotate    = false
        hum.WalkSpeed     = 0
        hum.JumpPower     = 0

        if not originalGravity then originalGravity = workspace.Gravity end
        workspace.Gravity = 0

        bodyVelocity          = Instance.new("BodyVelocity")
        bodyVelocity.MaxForce = Vector3.new(1e9, 1e9, 1e9)
        bodyVelocity.P        = 1e6
        bodyVelocity.Velocity = Vector3.zero
        bodyVelocity.Parent   = hrp

        bodyGyro           = Instance.new("BodyGyro")
        bodyGyro.MaxTorque = Vector3.new(1e9, 1e9, 1e9)
        bodyGyro.P         = 1e6
        bodyGyro.D         = 500
        bodyGyro.CFrame    = CFrame.new(hrp.Position)
        bodyGyro.Parent    = hrp
    end)
end

local function disablePhysics()
    pcall(function()
        if bodyVelocity then bodyVelocity:Destroy(); bodyVelocity = nil end
        if bodyGyro     then bodyGyro:Destroy();     bodyGyro     = nil end
        if originalGravity then
            workspace.Gravity = originalGravity
            originalGravity   = nil
        end
        local hum = getHumanoid()
        if hum then
            hum.PlatformStand = false
            hum.AutoRotate    = true
            hum.WalkSpeed     = 16
            hum.JumpPower     = 50
        end
    end)
end

local function moveTo(targetPos, speed, validCheck)
    local deadline  = os.clock() + MOVE_TIMEOUT
    local lastCheck = 0

    while arenaEnabled do
        local hrp = getHRP()
        if not hrp then return false end
        if not bodyVelocity or not bodyVelocity.Parent then
            enablePhysics()
            task.wait(0.05)
            hrp = getHRP()
            if not hrp then return false end
        end

        if os.clock() > deadline then return false end

        local now = os.clock()
        if validCheck and now - lastCheck > 0.05 then
            lastCheck = now
            if not validCheck() then
                if bodyVelocity and bodyVelocity.Parent then
                    bodyVelocity.Velocity = Vector3.zero
                end
                return false
            end
        end

        local diff = targetPos - hrp.Position
        local dist = diff.Magnitude
        if dist < ARRIVAL_THRESHOLD then
            if bodyVelocity and bodyVelocity.Parent then
                bodyVelocity.Velocity = Vector3.zero
            end
            return true
        end

        local s = math.min(speed, dist * 10)
        if bodyVelocity and bodyVelocity.Parent then
            bodyVelocity.Velocity = diff.Unit * s
        end
        task.wait()
    end

    if bodyVelocity and bodyVelocity.Parent then
        bodyVelocity.Velocity = Vector3.zero
    end
    return false
end

local function arcTo(targetPos, speed, validCheck)
    local hrp = getHRP()
    if not hrp then return false end

    if hrp.Position.Y < flyHeight - 3 then
        local up = Vector3.new(hrp.Position.X, flyHeight, hrp.Position.Z)
        if not moveTo(up, speed, validCheck) then return false end
    end

    local over = Vector3.new(targetPos.X, flyHeight, targetPos.Z)
    if not moveTo(over, speed, validCheck) then return false end

    return moveTo(targetPos, speed, validCheck)
end

local function interactWithModel(model, holdDuration)
    local hrp = getHRP()
    if not hrp then return end

    local part = getPartOf(model)
    if part then
        pcall(function()
            firetouchinterest(hrp, part, 0)
            task.wait(0.02)
            firetouchinterest(hrp, part, 1)
        end)
    end

    local prompts = {}
    for _, v in ipairs(model:GetDescendants()) do
        if v:IsA("ProximityPrompt") and v.Enabled then
            table.insert(prompts, v)
        end
    end

    for _, prompt in ipairs(prompts) do
        task.spawn(function()
            for _ = 1, 3 do
                pcall(function() fireproximityprompt(prompt) end)
                task.wait(0.04)
            end

            pcall(function() prompt:InputHoldBegin() end)
            task.wait(holdDuration + 0.1)
            pcall(function()
                if prompt and prompt.Parent then
                    prompt:InputHoldEnd()
                end
            end)
        end)
    end
end

local function hasBrainrotEquipped()
    local c = getCharacter()
    if c then
        for _, v in ipairs(c:GetChildren()) do
            if v:IsA("Model") and CollectionService:HasTag(v, "ArenaBrainrot") then
                return true
            end
        end
    end
    local pf = workspace:FindFirstChild(LocalPlayer.Name)
    if pf and pf:FindFirstChild("RenderedBrainrot") then return true end
    return false
end

local function getOwnBasePart()
    local now = os.clock()
    if cachedBasePart and cachedBasePart.Parent and now - cachedBaseRefresh < 10 then
        return cachedBasePart
    end
    local basesFolder = workspace:FindFirstChild("Bases")
    if not basesFolder then return nil end
    for _, folder in ipairs(basesFolder:GetChildren()) do
        if folder:GetAttribute("Holder") == LocalPlayer.UserId then
            local sp = folder:FindFirstChild("Spawn")
            if sp then
                cachedBasePart   = sp
                cachedBaseRefresh = now
                return sp
            end
            for _, p in ipairs(folder:GetDescendants()) do
                if p:IsA("BasePart") then
                    cachedBasePart   = p
                    cachedBaseRefresh = now
                    return p
                end
            end
        end
    end
    return nil
end

local characterReadySignal = nil

local function waitForRespawn()
    disablePhysics()
    local deadline = os.clock() + 30
    while os.clock() < deadline do
        if isAlive() and getHRP() then break end
        task.wait(0.2)
    end
    task.wait(0.5)
    enablePhysics()
end

local function runArenaLoop()
    local deathConn = nil
    local function hookDeath()
        local c = getCharacter()
        if not c then return end
        local hum = c:FindFirstChildOfClass("Humanoid")
        if not hum then return end
        deathConn = hum.Died:Connect(function()
            bodyVelocity  = nil
            bodyGyro      = nil
            originalGravity = nil
        end)
    end

    local charAddedConn = LocalPlayer.CharacterAdded:Connect(function()
        bodyVelocity    = nil
        bodyGyro        = nil
        originalGravity = nil
        hookDeath()
    end)
    hookDeath()

    while arenaEnabled do
        if not isAlive() or not getHRP() then
            disablePhysics()
            waitForRespawn()
            if not arenaEnabled then break end
            enablePhysics()
            continue
        end

        enablePhysics()

        local hrp = getHRP()
        if not hrp then task.wait(0.1); continue end

        if hasBrainrotEquipped() then
            local basePart = getOwnBasePart()
            if basePart then
                local basePos = Vector3.new(
                    basePart.Position.X,
                    basePart.Position.Y + 3,
                    basePart.Position.Z
                )

                if instantTeleport then
                    hrp.CFrame = CFrame.new(basePos)
                else
                    arcTo(basePos, arenaTweenSpeed, nil)
                end

                local waitEnd = os.clock() + 5
                while os.clock() < waitEnd and arenaEnabled do
                    if not hasBrainrotEquipped() then break end
                    local hrp2 = getHRP()
                    if hrp2 and basePart.Parent then
                        pcall(function()
                            firetouchinterest(hrp2, basePart, 0)
                            task.wait(0.05)
                            firetouchinterest(hrp2, basePart, 1)
                        end)
                    end
                    task.wait(0.05)
                end
            else
                task.wait(0.3)
            end
            continue
        end

        local target = getBestBrainrot(hrp.Position)
        if not target then
            if bodyVelocity and bodyVelocity.Parent then
                bodyVelocity.Velocity = Vector3.zero
            end
            task.wait(0.05)
            continue
        end

        local snapPos = getPartOf(target) and getPartOf(target).Position or nil
        if not snapPos then task.wait(0.02); continue end

        local trackTask = task.spawn(function()
            while arenaEnabled and brainrotStillAvailable(target) do
                local p = getPartOf(target)
                if p then snapPos = p.Position end
                task.wait(0.08)
            end
        end)

        local function targetOk()
            return brainrotStillAvailable(target) and getPartOf(target) ~= nil
        end

        local arrived = arcTo(snapPos, arenaTweenSpeed, targetOk)
        task.cancel(trackTask)

        if not arrived or not targetOk() then continue end

        interactWithModel(target, PICKUP_HOLD_DURATION)

        local waitEnd = os.clock() + PICKUP_HOLD_DURATION + 0.5
        while os.clock() < waitEnd and arenaEnabled do
            if hasBrainrotEquipped() then break end
            local hrp2 = getHRP()
            local part = getPartOf(target)
            if hrp2 and part and target.Parent then
                pcall(function()
                    firetouchinterest(hrp2, part, 0)
                    task.wait(0.02)
                    firetouchinterest(hrp2, part, 1)
                end)
            end
            task.wait(0.02)
        end

        if not hasBrainrotEquipped() then
            task.wait(0.05)
            continue
        end
    end

    if deathConn    then deathConn:Disconnect()    end
    if charAddedConn then charAddedConn:Disconnect() end
    disablePhysics()
end

