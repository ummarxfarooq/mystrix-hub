    if c then
        for _, v in ipairs(c:GetChildren()) do
            if v:IsA("Model") and CollectionService:HasTag(v, "ArenaBrainrot") then
                return true
            end
        end
    end
    local pf = workspace:FindFirstChild(LocalPlayer.Name)
    if pf and pf:FindFirstChild("RenderedBrainrot") then return true end
    return false
end

local function enablePhysics()
    local hrp = getHRP()
    local hum = getHumanoid()
    if not hrp or not hum then return end
    pcall(function()
        if bodyVelocity and bodyVelocity.Parent then bodyVelocity:Destroy() end
        if bodyGyro     and bodyGyro.Parent     then bodyGyro:Destroy()     end

        hum.PlatformStand = true
        hum.AutoRotate    = false
        hum.WalkSpeed     = 0
        hum.JumpPower     = 0

        if not originalGravity then originalGravity = workspace.Gravity end
        workspace.Gravity = 0

        bodyVelocity          = Instance.new("BodyVelocity")
        bodyVelocity.MaxForce = Vector3.new(1e9, 1e9, 1e9)
        bodyVelocity.P        = 1e6
        bodyVelocity.Velocity = Vector3.zero
        bodyVelocity.Parent   = hrp

        bodyGyro           = Instance.new("BodyGyro")
        bodyGyro.MaxTorque = Vector3.new(1e9, 1e9, 1e9)
        bodyGyro.P         = 1e6
        bodyGyro.D         = 500
        bodyGyro.CFrame    = CFrame.new(hrp.Position)
        bodyGyro.Parent    = hrp
    end)
end

local function disablePhysics()
    pcall(function()
        if bodyVelocity then bodyVelocity:Destroy(); bodyVelocity = nil end
        if bodyGyro     then bodyGyro:Destroy();     bodyGyro     = nil end
        if originalGravity then
            workspace.Gravity = originalGravity
            originalGravity   = nil
        end
        local hum = getHumanoid()
        if hum then
            hum.PlatformStand = false
            hum.AutoRotate    = true
            hum.WalkSpeed     = 16
            hum.JumpPower     = 50
        end
    end)
end

local function moveTo(targetPos, speed, validCheck)
    local deadline  = os.clock() + MOVE_TIMEOUT
    local lastCheck = 0

    while arenaEnabled do
        local hrp = getHRP()
        if not hrp then return false end
        if not bodyVelocity or not bodyVelocity.Parent then
            enablePhysics()
            task.wait(0.05)
            hrp = getHRP()
            if not hrp then return false end
        end

        if os.clock() > deadline then return false end

        local now = os.clock()
        if validCheck and now - lastCheck > 0.05 then
            lastCheck = now
            if not validCheck() then
                if bodyVelocity and bodyVelocity.Parent then
                    bodyVelocity.Velocity = Vector3.zero
                end
                return false
            end
        end

        local diff = targetPos - hrp.Position
        local dist = diff.Magnitude
        if dist < ARRIVAL_THRESHOLD then
            if bodyVelocity and bodyVelocity.Parent then
                bodyVelocity.Velocity = Vector3.zero
            end
            return true
        end

        local s = math.min(speed, dist * 10)
        if bodyVelocity and bodyVelocity.Parent then
            bodyVelocity.Velocity = diff.Unit * s
        end
        task.wait()
    end

    if bodyVelocity and bodyVelocity.Parent then
        bodyVelocity.Velocity = Vector3.zero
    end
    return false
end

local function arcTo(targetPos, speed, validCheck)
    local hrp = getHRP()
    if not hrp then return false end

    if hrp.Position.Y < flyHeight - 3 then
        local up = Vector3.new(hrp.Position.X, flyHeight, hrp.Position.Z)
        if not moveTo(up, speed, validCheck) then return false end
    end

    local over = Vector3.new(targetPos.X, flyHeight, targetPos.Z)
    if not moveTo(over, speed, validCheck) then return false end

    return moveTo(targetPos, speed, validCheck)
end

local function moveToWaitPosition()
    if not firstBrainrotSecured then return end

    local hrp = getHRP()
    if not hrp then return end
    if (hrp.Position - WAIT_POSITION).Magnitude < 5 then return end

    local function valid()
        if not arenaEnabled then return false end
        if hasBrainrotEquipped() then return false end
        if #getAvailableBrainrots() > 0 then return false end
        return true
    end

    if hrp.Position.Y < flyHeight - 3 then
        local up = Vector3.new(hrp.Position.X, flyHeight, hrp.Position.Z)
        if not moveTo(up, arenaTweenSpeed, valid) then return end
    end
    local over = Vector3.new(WAIT_POSITION.X, flyHeight, WAIT_POSITION.Z)
    if not moveTo(over, arenaTweenSpeed, valid) then return end
    moveTo(WAIT_POSITION, arenaTweenSpeed, valid)
end

local function returnToBase()
    local basePart = getOwnBasePart()
    if not basePart then return end

    local basePos = Vector3.new(
        basePart.Position.X,
        basePart.Position.Y + 3,
        basePart.Position.Z
    )

    local hrp = getHRP()
    if not hrp then return end

    if instantTeleport then
        hrp.CFrame = CFrame.new(basePos)
    else
        arcTo(basePos, arenaTweenSpeed, nil)
    end

    local waitEnd = os.clock() + 5
    while os.clock() < waitEnd and arenaEnabled do
        if not hasBrainrotEquipped() then break end
        local hrp2 = getHRP()
        if hrp2 and basePart.Parent then
            pcall(function()
                firetouchinterest(hrp2, basePart, 0)
                task.wait(0.05)
                firetouchinterest(hrp2, basePart, 1)
            end)
        end
        task.wait(0.05)
    end

    firstBrainrotSecured = true
    if arenaEnabled then
        moveToWaitPosition()
    end
end

local function getHarpoonGun()
    local function isHarpoon(tool)
        if not tool:IsA("Tool") then return false end
        if CollectionService:HasTag(tool, "HarpoonGun") then return true end
        if tool:GetAttribute("GearType") == "Harpoon Gun" then return true end
        if tool:GetAttribute("DisplayName") == "Harpoon Gun" then return true end
        if tool.Name:lower():find("harpoon") then return true end
        return false
    end

    local bp = LocalPlayer:FindFirstChild("Backpack")
    if bp then
        for _, tool in ipairs(bp:GetChildren()) do
            if isHarpoon(tool) then return tool end
        end
    end
    local c = getCharacter()
    if c then
        for _, tool in ipairs(c:GetChildren()) do
            if isHarpoon(tool) then return tool end
        end
    end
    return nil
end

local function isHarpoonReady(harpoon)
    if not harpoon or not harpoon.Parent then return false end
    local cooldownUntil = harpoon:GetAttribute("CooldownUntil")
    if cooldownUntil and workspace:GetServerTimeNow() < cooldownUntil then
        return false
    end
    return true
end

local function getPickupId(target)
    local id = target:GetAttribute("_PickupId")
    if id then return id end
    local parent = target.Parent
    while parent and parent ~= workspace do
        id = parent:GetAttribute("_PickupId")
        if id then return id end
        parent = parent.Parent
    end
    return nil
end

local function fireHarpoon(targetPos, pickupId)
    local ok = pcall(function()
        local remote = game:GetService("ReplicatedStorage")
            :FindFirstChild("Shared")
            :FindFirstChild("Remotes")
            :FindFirstChild("Networking")
            :FindFirstChild("RE/Harpoon/HarpoonActivate")
        if remote then
            remote:FireServer(targetPos, pickupId)
        end
    end)
    if not ok then
        pcall(function()
            local rs = game:GetService("ReplicatedStorage")
            local remotes = rs:FindFirstChild("Shared") and
                rs.Shared:FindFirstChild("Remotes")
            if remotes then
                local net = remotes:FindFirstChild("Networking")
                if net then
                    local r = net:FindFirstChild("RE/Harpoon/HarpoonActivate")
                    if r then r:FireServer(targetPos, pickupId) end
                end
            end
        end)
    end
end

local function tryHarpoonPickup(target, targetOk)
    if not autoHarpoon then return false end

    local harpoon = getHarpoonGun()
    if not harpoon then return false end

    if not isHarpoonReady(harpoon) then return false end

    local part = getPartOf(target)
    if not part then return false end

    local hoverPos = Vector3.new(part.Position.X, part.Position.Y + HARPOON_HOVER_HEIGHT, part.Position.Z)

    local hrp = getHRP()
    if not hrp then return false end

    if hrp.Position.Y < flyHeight - 3 then
        local up = Vector3.new(hrp.Position.X, flyHeight, hrp.Position.Z)
        if not moveTo(up, arenaTweenSpeed, targetOk) then return false end
    end
    local over = Vector3.new(hoverPos.X, flyHeight, hoverPos.Z)
    if not moveTo(over, arenaTweenSpeed, targetOk) then return false end
    if not moveTo(hoverPos, arenaTweenSpeed, targetOk) then return false end

    if bodyVelocity and bodyVelocity.Parent then
        bodyVelocity.Velocity = Vector3.zero
    end

    local readyWait = os.clock() + 2
    while os.clock() < readyWait and arenaEnabled do
        if LocalPlayer:GetAttribute("HarpoonReady") then break end
        if not targetOk() then return false end
        task.wait(0.05)
    end

    if not isHarpoonReady(harpoon) then return false end
    if not targetOk() then return false end

    part = getPartOf(target)
    if not part then return false end

    local pickupId = getPickupId(target)
    fireHarpoon(part.Position, pickupId)

    local waitEnd = os.clock() + 1.0
    while os.clock() < waitEnd do
        if hasBrainrotEquipped() then return true end
        if not targetOk() then break end
        task.wait(0.02)
    end

    return hasBrainrotEquipped()
end

local function interactWithModel(model, holdDuration)
    local hrp = getHRP()
    if not hrp then return end

    local part = getPartOf(model)
    if part then
        pcall(function()
            firetouchinterest(hrp, part, 0)
            task.wait(0.02)
            firetouchinterest(hrp, part, 1)
        end)
    end

    local prompts = {}
    for _, v in ipairs(model:GetDescendants()) do
        if v:IsA("ProximityPrompt") and v.Enabled then
            table.insert(prompts, v)
        end
    end

    for _, prompt in ipairs(prompts) do
        local duration = (prompt.HoldDuration and prompt.HoldDuration > 0)
            and prompt.HoldDuration
            or holdDuration

        local ok = pcall(function()
            holdproximityprompt(prompt, duration)
        end)

        if not ok then
            pcall(function() prompt:InputHoldBegin() end)
            local elapsed = 0
            while elapsed < duration + 0.15 do
                if not prompt or not prompt.Parent then break end
                if part and part.Parent then
                    pcall(function()
                        local h = getHRP()
                        if h then
                            firetouchinterest(h, part, 0)
                            firetouchinterest(h, part, 1)
                        end
                    end)
                end
                task.wait(0.03)
                elapsed = elapsed + 0.03
            end
            pcall(function()
                if prompt and prompt.Parent then prompt:InputHoldEnd() end
            end)
        end
    end
end

local function waitForRespawn()
    disablePhysics()
    local deadline = os.clock() + 30
    while os.clock() < deadline do
        if isAlive() and getHRP() then break end
        task.wait(0.2)
    end
    task.wait(0.5)
    enablePhysics()
end

local instantTeleportConn = nil

local function startInstantTeleportWatch()
    if instantTeleportConn then return end
    instantTeleportConn = RunService.Heartbeat:Connect(function()
        if not instantTeleport then return end
        if arenaEnabled then return end
        if not hasBrainrotEquipped() then return end
        local basePart = getOwnBasePart()
        if not basePart then return end
        local hrp = getHRP()
        if not hrp then return end
        hrp.CFrame = CFrame.new(
            basePart.Position.X,
            basePart.Position.Y + 3,
            basePart.Position.Z
        )
    end)
end

startInstantTeleportWatch()

local function runArenaLoop()
    local deathConn = nil
    local function hookDeath()
        local c = getCharacter()
        if not c then return end
        local hum = c:FindFirstChildOfClass("Humanoid")
        if not hum then return end
        deathConn = hum.Died:Connect(function()
            bodyVelocity    = nil
            bodyGyro        = nil
            originalGravity = nil
        end)
    end

    local charAddedConn = LocalPlayer.CharacterAdded:Connect(function()
        bodyVelocity    = nil
        bodyGyro        = nil
        originalGravity = nil
        hookDeath()
    end)
    hookDeath()

    while arenaEnabled do
        if not isAlive() or not getHRP() then
            disablePhysics()
            waitForRespawn()
            if not arenaEnabled then break end
            enablePhysics()
            continue
        end

        enablePhysics()

        local hrp = getHRP()
        if not hrp then task.wait(0.1); continue end

        if hasBrainrotEquipped() then
            returnToBase()
            continue
        end

        local target = getBestBrainrot(hrp.Position)
        if not target then
            moveToWaitPosition()
            task.wait(0.1)
            continue
        end

        local snapPos = getPartOf(target) and getPartOf(target).Position or nil
        if not snapPos then task.wait(0.02); continue end

        local trackTask = task.spawn(function()
            while arenaEnabled and brainrotStillAvailable(target) do
                local p = getPartOf(target)
                if p then snapPos = p.Position end
                task.wait(0.08)
            end
        end)

        local function targetOk()
            return brainrotStillAvailable(target) and getPartOf(target) ~= nil
        end

        if autoHarpoon and getHarpoonGun() then
            local harpoonGot = tryHarpoonPickup(target, targetOk)
            task.cancel(trackTask)

            if harpoonGot then
                returnToBase()
                continue
            end

            if not targetOk() then continue end

            local part = getPartOf(target)
            if not part then continue end
            if not moveTo(part.Position, arenaTweenSpeed, targetOk) then continue end
            if not targetOk() then continue end

            interactWithModel(target, PICKUP_HOLD_DURATION)
            if hasBrainrotEquipped() then returnToBase(); continue end
            if targetOk() then
                interactWithModel(target, PICKUP_HOLD_DURATION)
            end
            if hasBrainrotEquipped() then returnToBase() end
            if not hasBrainrotEquipped() then task.wait(0.05) end
            continue
        end

        local arrived = arcTo(snapPos, arenaTweenSpeed, targetOk)
        task.cancel(trackTask)

        if not arrived or not targetOk() then continue end

        interactWithModel(target, PICKUP_HOLD_DURATION)
        if hasBrainrotEquipped() then
            returnToBase()
            continue
        end

        if targetOk() then
            interactWithModel(target, PICKUP_HOLD_DURATION)
        end
        if hasBrainrotEquipped() then
            returnToBase()
            continue
        end

        task.wait(0.05)
    end

    if deathConn     then deathConn:Disconnect()     end
    if charAddedConn then charAddedConn:Disconnect() end
    disablePhysics()
end

