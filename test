local function getBrainrotRarity(name)
    return BrainrotToRarity[name] or "Common"
end



local PICKUP_HOLD_DURATION  = 3.0
local ARRIVAL_THRESHOLD     = 2.0
local MOVE_TIMEOUT          = 25
local WAIT_POSITION         = Vector3.new(1818, 3, 2681)
local HARPOON_HOVER_HEIGHT  = 25
local HARPOON_COOLDOWN      = 8

local arenaEnabled          = false
local arenaLoop             = nil
local arenaTweenSpeed       = 500
local flyHeight             = 50
local instantTeleport       = false
local selectedRarities      = {"Any"}
